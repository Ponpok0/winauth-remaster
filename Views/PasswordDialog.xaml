<Window x:Class="WinAuthRemaster.Views.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Password_Title}" Width="360" Height="280"
        Background="{DynamicResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize">

    <Grid>
        <!-- ☓ボタン（右上）— トレイ格納ではなく最小化 -->
        <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,8,8,0" Panel.ZIndex="1"
                Click="OnMinimizeClick"
                Style="{StaticResource ModernButton}"
                Padding="6,4" ToolTip="{DynamicResource Tip_MinimizeToTray}">
            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14"
                       Text="&#xE711;"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
        </Button>

        <!-- メインコンテンツ（ロック画面と同じ中央配置） -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                    Width="280">
            <!-- Title -->
            <TextBlock x:Name="TitleText"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       FontSize="20" FontWeight="Bold"
                       FontFamily="{StaticResource UIFont}"
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <!-- Password -->
            <TextBlock Text="{DynamicResource Password_Label}" Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="12" Margin="0,0,0,4"/>
            <PasswordBox x:Name="PasswordInput"
                         Style="{StaticResource ModernPasswordBox}" MaxLength="128" Margin="0,0,0,12"
                         KeyDown="OnKeyDown"/>

            <!-- Confirm (set mode only) -->
            <StackPanel x:Name="ConfirmPanel" Visibility="Collapsed">
                <TextBlock Text="{DynamicResource Password_Confirm}" Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="12" Margin="0,0,0,4"/>
                <PasswordBox x:Name="ConfirmInput"
                             Style="{StaticResource ModernPasswordBox}" MaxLength="128" Margin="0,0,0,12"
                             KeyDown="OnKeyDown"/>
            </StackPanel>

            <!-- OK / Cancel -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="CancelButton" Content="{DynamicResource Btn_Cancel}" Style="{StaticResource ModernButton}"
                        Click="OnCancel" Margin="0,0,8,0" Width="80"/>
                <Button x:Name="OkButton" Content="{DynamicResource Btn_OK}" Style="{StaticResource PrimaryButton}"
                        Click="OnOk" Width="120"/>
            </StackPanel>

            <!-- Error message -->
            <TextBlock x:Name="ErrorText"
                       Foreground="{DynamicResource DangerBrush}"
                       FontSize="12" HorizontalAlignment="Center"
                       Margin="0,12,0,0" TextWrapping="Wrap"
                       Visibility="Collapsed"/>
        </StackPanel>

        <!-- 終了ボタン（右下） -->
        <Button HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,8,8"
                Click="OnExitClick"
                Style="{StaticResource ModernButton}"
                Padding="4,2" ToolTip="{DynamicResource Tip_Exit}">
            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="11"
                       Text="&#xE7E8;"
                       Foreground="{DynamicResource DangerBrush}"/>
        </Button>
    </Grid>
</Window>
