<Window x:Class="WinAuthRemaster.Views.AddAuthenticatorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Add_Title}" Width="440" Height="480"
        Background="{DynamicResource BackgroundBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Name -->
        <TextBlock Grid.Row="0" Text="{DynamicResource Add_Name}" Foreground="{DynamicResource TextSecondaryBrush}"
                   FontSize="12" Margin="0,0,0,4"/>
        <TextBox Grid.Row="1" x:Name="NameBox" Style="{StaticResource ModernTextBox}"
                 MaxLength="20" Width="240" HorizontalAlignment="Left" Margin="0,0,0,12"/>

        <!-- Secret Key / otpauth URI -->
        <TextBlock Grid.Row="2" Text="{DynamicResource Add_SecretKey}"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   FontSize="12" Margin="0,0,0,4"/>
        <TextBox Grid.Row="3" x:Name="SecretBox" Style="{StaticResource ModernTextBox}"
                 FontFamily="{StaticResource MonoFont}" MaxLength="256" Margin="0,0,0,12"/>

        <!-- Preset -->
        <TextBlock Grid.Row="4" Text="{DynamicResource Add_Preset}" Foreground="{DynamicResource TextSecondaryBrush}"
                   FontSize="12" Margin="0,0,0,4"/>
        <ComboBox Grid.Row="5" x:Name="PresetBox" Margin="0,0,0,12"/>

        <!-- Advanced Options -->
        <Grid Grid.Row="6" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Text="{DynamicResource Add_Algorithm}" Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="12" Margin="0,0,0,4"/>
                <ComboBox x:Name="AlgorithmBox" SelectedIndex="0">
                    <ComboBoxItem Content="HMAC-SHA1"/>
                    <ComboBoxItem Content="HMAC-SHA256"/>
                    <ComboBoxItem Content="HMAC-SHA512"/>
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="4,0">
                <TextBlock Text="{DynamicResource Add_Period}" Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="12" Margin="0,0,0,4"/>
                <TextBox x:Name="PeriodBox" Style="{StaticResource ModernTextBox}" Text="30"
                         MaxLength="3"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Margin="8,0,0,0">
                <TextBlock Text="{DynamicResource Add_Digits}" Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="12" Margin="0,0,0,4"/>
                <TextBox x:Name="DigitsBox" Style="{StaticResource ModernTextBox}" Text="6"
                         MaxLength="1"/>
            </StackPanel>
        </Grid>

        <!-- Algorithm hint -->
        <TextBlock Grid.Row="7" x:Name="AlgorithmHint"
                   Foreground="{DynamicResource TextMutedBrush}"
                   FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"/>

        <!-- Preview -->
        <Border Grid.Row="8" Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                Padding="16,12" Margin="0,0,0,12"
                VerticalAlignment="Bottom">
            <StackPanel>
                <TextBlock Text="{DynamicResource Add_Preview}" Foreground="{DynamicResource TextMutedBrush}" FontSize="11"/>
                <TextBlock x:Name="PreviewCode"
                           Foreground="{DynamicResource SecondaryBrush}"
                           FontFamily="{StaticResource MonoFont}" FontSize="24" FontWeight="Bold"
                           Margin="0,4,0,0" Text="--- ---"/>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource Btn_Cancel}" Style="{StaticResource ModernButton}"
                    Click="OnCancel" Margin="0,0,8,0" Width="80"/>
            <Button Content="{DynamicResource Btn_OK}" Style="{StaticResource PrimaryButton}"
                    Click="OnOk" Width="80"/>
        </StackPanel>
    </Grid>
</Window>
