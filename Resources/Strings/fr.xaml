<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:s="clr-namespace:System;assembly=System.Runtime">

    <!-- Toolbar tooltips -->
    <s:String x:Key="Tip_MinimizeToTray">Réduire dans la zone de notification</s:String>
    <s:String x:Key="Tip_AlwaysOnTop">Toujours au premier plan</s:String>
    <s:String x:Key="Tip_Settings">Paramètres</s:String>
    <s:String x:Key="Tip_Menu">Menu</s:String>
    <s:String x:Key="Tip_MoreActions">Plus d'actions</s:String>
    <s:String x:Key="Tip_ShowHideCode">Afficher / Masquer le code</s:String>
    <s:String x:Key="Tip_CopyToClipboard">Copier dans le presse-papiers</s:String>
    <s:String x:Key="Tip_Exit">Quitter</s:String>

    <!-- Toolbar / buttons -->
    <s:String x:Key="Btn_Add">+ Ajouter</s:String>
    <s:String x:Key="Btn_Copy">Copier</s:String>
    <s:String x:Key="Btn_Unlock">Déverrouiller</s:String>
    <s:String x:Key="Btn_ClickToUnlock">Cliquer pour déverrouiller</s:String>
    <s:String x:Key="Btn_Browse">Parcourir...</s:String>
    <s:String x:Key="Btn_OK">OK</s:String>
    <s:String x:Key="Btn_Cancel">Annuler</s:String>
    <s:String x:Key="Btn_Save">Enregistrer</s:String>
    <s:String x:Key="Btn_Delete">Supprimer</s:String>
    <s:String x:Key="Btn_Import">Importer</s:String>
    <s:String x:Key="Btn_Export">Exporter</s:String>
    <s:String x:Key="Btn_Password">Mot de passe</s:String>

    <!-- Hamburger menu -->
    <s:String x:Key="Menu_New">Nouveau</s:String>
    <s:String x:Key="Menu_Import">Importer</s:String>
    <s:String x:Key="Menu_Export">Exporter</s:String>
    <s:String x:Key="Menu_Password">Mot de passe</s:String>
    <s:String x:Key="Menu_Settings">Paramètres</s:String>
    <s:String x:Key="Menu_Close">Fermer</s:String>
    <s:String x:Key="Menu_Exit">Quitter</s:String>

    <!-- Card context menu -->
    <s:String x:Key="Menu_Color">Couleur</s:String>
    <s:String x:Key="Menu_ResetColor">Réinitialiser</s:String>
    <s:String x:Key="Menu_Rename">Renommer</s:String>
    <s:String x:Key="Menu_Delete">Supprimer</s:String>

    <!-- System tray -->
    <s:String x:Key="Tray_Show">Afficher</s:String>
    <s:String x:Key="Tray_Exit">Quitter</s:String>

    <!-- Lock overlay -->
    <s:String x:Key="Lock_Title">Verrouillé</s:String>
    <s:String x:Key="Lock_EnterPassword">Saisissez le mot de passe pour déverrouiller :</s:String>
    <s:String x:Key="Lock_WrongPassword">Mot de passe incorrect.</s:String>

    <!-- Empty state -->
    <s:String x:Key="EmptyState">Aucun authentificateur. Cliquez sur « + Ajouter » ou « Importer » pour commencer.</s:String>

    <!-- Toast -->
    <s:String x:Key="Toast_Copied">Copié !</s:String>

    <!-- Status messages -->
    <s:String x:Key="Status_Deleted">« {0} » supprimé. Sauvegarde enregistrée.</s:String>
    <s:String x:Key="Status_SettingsSaved">Paramètres enregistrés.</s:String>
    <s:String x:Key="Status_Imported">{0} authentificateur(s) importé(s).</s:String>
    <s:String x:Key="Status_NoAuthFound">Aucun authentificateur trouvé dans le fichier.</s:String>
    <s:String x:Key="Status_NothingToExport">Rien à exporter.</s:String>
    <s:String x:Key="Status_Exported">{0} authentificateur(s) exporté(s).</s:String>
    <s:String x:Key="Status_PasswordRemoved">Protection par mot de passe supprimée.</s:String>
    <s:String x:Key="Status_PasswordUpdated">Protection par mot de passe mise à jour.</s:String>

    <!-- Settings dialog -->
    <s:String x:Key="Settings_Title">Paramètres</s:String>
    <s:String x:Key="Settings_DataFile">Emplacement du fichier de données :</s:String>
    <s:String x:Key="Settings_AutoLock">Verrouillage automatique (minutes, 0 = désactivé) :</s:String>
    <s:String x:Key="Settings_Theme">Thème :</s:String>
    <s:String x:Key="Settings_Dark">Sombre</s:String>
    <s:String x:Key="Settings_Light">Clair</s:String>
    <s:String x:Key="Settings_Language">Langue :</s:String>
    <s:String x:Key="Settings_Opacity">Opacité de la fenêtre :</s:String>
    <s:String x:Key="Settings_InvalidTimeout">Veuillez entrer une valeur valide (0–1440 minutes).</s:String>
    <s:String x:Key="Settings_Hotkey">Raccourci global (afficher/masquer) :</s:String>
    <s:String x:Key="Settings_HotkeyClear">Effacer</s:String>
    <s:String x:Key="Settings_HotkeyHint">Appuyez sur les touches de raccourci...</s:String>
    <s:String x:Key="Settings_HotkeyFailed">Échec de l'enregistrement du raccourci. Une autre application utilise peut-être cette combinaison.</s:String>

    <!-- Add authenticator dialog -->
    <s:String x:Key="Add_Title">Ajouter un authentificateur</s:String>
    <s:String x:Key="Add_Name">Nom</s:String>
    <s:String x:Key="Add_SecretKey">Clé secrète (Base32) ou URI otpauth://</s:String>
    <s:String x:Key="Add_Algorithm">Algorithme</s:String>
    <s:String x:Key="Add_Period">Intervalle (sec.)</s:String>
    <s:String x:Key="Add_Digits">Chiffres</s:String>
    <s:String x:Key="Add_Preview">Aperçu</s:String>
    <s:String x:Key="Add_EnterName">Veuillez entrer un nom.</s:String>
    <s:String x:Key="Add_EnterSecret">Veuillez entrer une clé secrète.</s:String>
    <s:String x:Key="Add_InvalidSecret">Clé Base32 non valide.</s:String>
    <s:String x:Key="Add_InvalidPeriod">L'intervalle doit être entre 10 et 300 secondes.</s:String>
    <s:String x:Key="Add_InvalidDigits">Le nombre de chiffres doit être entre 4 et 8.</s:String>
    <s:String x:Key="Add_Validation">Validation</s:String>
    <s:String x:Key="Add_Preset">Préréglage</s:String>
    <s:String x:Key="Add_HintUseCustom">Si votre service nécessite des paramètres spéciaux (algorithme, intervalle ou nombre de chiffres non standard), sélectionnez « Personnalisé ».</s:String>
    <s:String x:Key="Add_HintSHA1">La plupart des services utilisent SHA-1. Ne modifiez que si votre service l'exige.</s:String>
    <s:String x:Key="Add_HintSHA256">SHA-256 est utilisé par certains services bancaires et d'entreprise.</s:String>
    <s:String x:Key="Add_HintSHA512">SHA-512 est rarement utilisé. Consultez la documentation de votre service.</s:String>
    <s:String x:Key="Preset_Custom">Personnalisé</s:String>
    <s:String x:Key="Preset_Standard">Standard : Google, GitHub, Microsoft, Discord, Amazon, X, etc.</s:String>

    <!-- Confirm delete dialog -->
    <s:String x:Key="Delete_Title">Confirmer la suppression</s:String>
    <s:String x:Key="Delete_Message">Supprimer « {0} » ?</s:String>
    <s:String x:Key="Delete_TypeToConfirmPrefix">Saisissez</s:String>
    <s:String x:Key="Delete_TypeToConfirmKeyword">delete me</s:String>
    <s:String x:Key="Delete_TypeToConfirmSuffix">pour confirmer :</s:String>

    <!-- Rename dialog -->
    <s:String x:Key="Rename_Title">Renommer</s:String>
    <s:String x:Key="Rename_Name">Nom</s:String>

    <!-- Password dialog -->
    <s:String x:Key="Password_Title">Mot de passe</s:String>
    <s:String x:Key="Password_Label">Mot de passe</s:String>
    <s:String x:Key="Password_Confirm">Confirmer le mot de passe</s:String>
    <s:String x:Key="Password_EnterPassword">Veuillez entrer un mot de passe.</s:String>
    <s:String x:Key="Password_DontMatch">Les mots de passe ne correspondent pas.</s:String>
    <s:String x:Key="Password_Error">Erreur</s:String>

    <!-- Password dialog titles -->
    <s:String x:Key="PwTitle_WinAuth">Saisir le mot de passe WinAuth</s:String>
    <s:String x:Key="PwTitle_FilePassword">Saisir le mot de passe du fichier</s:String>
    <s:String x:Key="PwTitle_SetExport">Définir le mot de passe d'exportation</s:String>
    <s:String x:Key="PwTitle_SetProtection">Définir la protection par mot de passe</s:String>

    <!-- File dialogs -->
    <s:String x:Key="FileDialog_ImportTitle">Importer des authentificateurs</s:String>
    <s:String x:Key="FileDialog_ExportTitle">Exporter des authentificateurs</s:String>
    <s:String x:Key="FileDialog_ChooseLocation">Choisir l'emplacement du fichier de données</s:String>

    <!-- Error messages -->
    <s:String x:Key="Error_ImportFailed">Échec de l'importation :</s:String>
    <s:String x:Key="Error_ExportFailed">Échec de l'exportation :</s:String>
    <s:String x:Key="Error_WrongPassword">Mot de passe incorrect.</s:String>
    <s:String x:Key="Error_ImportError">Erreur d'importation</s:String>
    <s:String x:Key="Error_ExportError">Erreur d'exportation</s:String>

</ResourceDictionary>
