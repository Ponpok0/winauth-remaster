<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:s="clr-namespace:System;assembly=System.Runtime">

    <!-- Toolbar tooltips -->
    <s:String x:Key="Tip_MinimizeToTray">Minimize to tray</s:String>
    <s:String x:Key="Tip_AlwaysOnTop">Always on top</s:String>
    <s:String x:Key="Tip_Settings">Settings</s:String>
    <s:String x:Key="Tip_Menu">Menu</s:String>
    <s:String x:Key="Tip_MoreActions">More actions</s:String>
    <s:String x:Key="Tip_ShowHideCode">Show / Hide code</s:String>
    <s:String x:Key="Tip_CopyToClipboard">Copy to clipboard</s:String>
    <s:String x:Key="Tip_Exit">Exit</s:String>

    <!-- Toolbar / buttons -->
    <s:String x:Key="Btn_Add">+ Add</s:String>
    <s:String x:Key="Btn_Copy">Copy</s:String>
    <s:String x:Key="Btn_Unlock">Unlock</s:String>
    <s:String x:Key="Btn_ClickToUnlock">Click to unlock</s:String>
    <s:String x:Key="Btn_Browse">Browse...</s:String>
    <s:String x:Key="Btn_OK">OK</s:String>
    <s:String x:Key="Btn_Cancel">Cancel</s:String>
    <s:String x:Key="Btn_Save">Save</s:String>
    <s:String x:Key="Btn_Delete">Delete</s:String>
    <s:String x:Key="Btn_Import">Import</s:String>
    <s:String x:Key="Btn_Export">Export</s:String>
    <s:String x:Key="Btn_Password">Password</s:String>

    <!-- Hamburger menu -->
    <s:String x:Key="Menu_New">New</s:String>
    <s:String x:Key="Menu_Import">Import</s:String>
    <s:String x:Key="Menu_Export">Export</s:String>
    <s:String x:Key="Menu_Password">Password</s:String>
    <s:String x:Key="Menu_Settings">Settings</s:String>
    <s:String x:Key="Menu_Close">Close</s:String>
    <s:String x:Key="Menu_Exit">Exit</s:String>

    <!-- Card context menu -->
    <s:String x:Key="Menu_Color">Color</s:String>
    <s:String x:Key="Menu_ResetColor">Reset</s:String>
    <s:String x:Key="Menu_Rename">Rename</s:String>
    <s:String x:Key="Menu_Delete">Delete</s:String>

    <!-- System tray -->
    <s:String x:Key="Tray_Show">Show</s:String>
    <s:String x:Key="Tray_Exit">Exit</s:String>

    <!-- Lock overlay -->
    <s:String x:Key="Lock_Title">Locked</s:String>
    <s:String x:Key="Lock_EnterPassword">Enter password to unlock:</s:String>
    <s:String x:Key="Lock_WrongPassword">Wrong password.</s:String>

    <!-- Empty state -->
    <s:String x:Key="EmptyState">No authenticators yet. Click '+ Add' or 'Import' to get started.</s:String>

    <!-- Toast -->
    <s:String x:Key="Toast_Copied">Copied!</s:String>

    <!-- Status messages -->
    <s:String x:Key="Status_Deleted">Deleted '{0}'. Backup saved.</s:String>
    <s:String x:Key="Status_SettingsSaved">Settings saved.</s:String>
    <s:String x:Key="Status_Imported">Imported {0} authenticator(s).</s:String>
    <s:String x:Key="Status_NoAuthFound">No authenticators found in file.</s:String>
    <s:String x:Key="Status_NothingToExport">Nothing to export.</s:String>
    <s:String x:Key="Status_Exported">Exported {0} authenticator(s).</s:String>
    <s:String x:Key="Status_PasswordRemoved">Password protection removed.</s:String>
    <s:String x:Key="Status_PasswordUpdated">Password protection updated.</s:String>

    <!-- Settings dialog -->
    <s:String x:Key="Settings_Title">Settings</s:String>
    <s:String x:Key="Settings_DataFile">Data file location:</s:String>
    <s:String x:Key="Settings_AutoLock">Auto-lock timeout (minutes, 0 = disabled):</s:String>
    <s:String x:Key="Settings_Theme">Theme:</s:String>
    <s:String x:Key="Settings_Dark">Dark</s:String>
    <s:String x:Key="Settings_Light">Light</s:String>
    <s:String x:Key="Settings_Language">Language:</s:String>
    <s:String x:Key="Settings_Opacity">Window opacity:</s:String>
    <s:String x:Key="Settings_InvalidTimeout">Please enter a valid timeout (0-1440 minutes).</s:String>
    <s:String x:Key="Settings_Hotkey">Global hotkey (show/hide):</s:String>
    <s:String x:Key="Settings_HotkeyClear">Clear</s:String>
    <s:String x:Key="Settings_HotkeyHint">Press shortcut keys...</s:String>
    <s:String x:Key="Settings_HotkeyFailed">Hotkey registration failed. Another app may be using this shortcut.</s:String>

    <!-- Add authenticator dialog -->
    <s:String x:Key="Add_Title">Add Authenticator</s:String>
    <s:String x:Key="Add_Name">Name</s:String>
    <s:String x:Key="Add_SecretKey">Secret Key (Base32) or otpauth:// URI</s:String>
    <s:String x:Key="Add_Algorithm">Algorithm</s:String>
    <s:String x:Key="Add_Period">Period (sec)</s:String>
    <s:String x:Key="Add_Digits">Digits</s:String>
    <s:String x:Key="Add_Preview">Preview</s:String>
    <s:String x:Key="Add_EnterName">Please enter a name.</s:String>
    <s:String x:Key="Add_EnterSecret">Please enter a secret key.</s:String>
    <s:String x:Key="Add_InvalidSecret">Invalid Base32 secret key.</s:String>
    <s:String x:Key="Add_InvalidPeriod">Period must be between 10 and 300 seconds.</s:String>
    <s:String x:Key="Add_InvalidDigits">Digits must be between 4 and 8.</s:String>
    <s:String x:Key="Add_Validation">Validation</s:String>
    <s:String x:Key="Add_Preset">Preset</s:String>
    <s:String x:Key="Add_HintUseCustom">If your service requires special settings (non-standard algorithm, period, or digits), select "Custom".</s:String>
    <s:String x:Key="Add_HintSHA1">Most services use SHA-1. Change only if your service specifies otherwise.</s:String>
    <s:String x:Key="Add_HintSHA256">SHA-256 is used by some enterprise and banking services.</s:String>
    <s:String x:Key="Add_HintSHA512">SHA-512 is rarely used. Check your service's documentation.</s:String>
    <s:String x:Key="Preset_Custom">Custom</s:String>
    <s:String x:Key="Preset_Standard">Standard: Google, GitHub, Microsoft, Discord, Amazon, X, etc.</s:String>

    <!-- Confirm delete dialog -->
    <s:String x:Key="Delete_Title">Confirm Delete</s:String>
    <s:String x:Key="Delete_Message">Delete '{0}'?</s:String>
    <s:String x:Key="Delete_TypeToConfirmPrefix">Type</s:String>
    <s:String x:Key="Delete_TypeToConfirmKeyword">delete me</s:String>
    <s:String x:Key="Delete_TypeToConfirmSuffix">to confirm:</s:String>

    <!-- Rename dialog -->
    <s:String x:Key="Rename_Title">Rename</s:String>
    <s:String x:Key="Rename_Name">Name</s:String>

    <!-- Password dialog -->
    <s:String x:Key="Password_Title">Password</s:String>
    <s:String x:Key="Password_Label">Password</s:String>
    <s:String x:Key="Password_Confirm">Confirm Password</s:String>
    <s:String x:Key="Password_EnterPassword">Please enter a password.</s:String>
    <s:String x:Key="Password_DontMatch">Passwords don't match.</s:String>
    <s:String x:Key="Password_Error">Error</s:String>

    <!-- Password dialog titles (from code-behind) -->
    <s:String x:Key="PwTitle_WinAuth">Enter WinAuth password</s:String>
    <s:String x:Key="PwTitle_FilePassword">Enter file password</s:String>
    <s:String x:Key="PwTitle_SetExport">Set export password</s:String>
    <s:String x:Key="PwTitle_SetProtection">Set password protection</s:String>

    <!-- File dialogs -->
    <s:String x:Key="FileDialog_ImportTitle">Import Authenticators</s:String>
    <s:String x:Key="FileDialog_ExportTitle">Export Authenticators</s:String>
    <s:String x:Key="FileDialog_ChooseLocation">Choose data file location</s:String>

    <!-- Error messages -->
    <s:String x:Key="Error_ImportFailed">Import failed:</s:String>
    <s:String x:Key="Error_ExportFailed">Export failed:</s:String>
    <s:String x:Key="Error_WrongPassword">Wrong password.</s:String>
    <s:String x:Key="Error_ImportError">Import Error</s:String>
    <s:String x:Key="Error_ExportError">Export Error</s:String>

</ResourceDictionary>
