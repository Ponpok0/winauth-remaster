<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:s="clr-namespace:System;assembly=System.Runtime">

    <!-- Toolbar tooltips -->
    <s:String x:Key="Tip_MinimizeToTray">In den Infobereich minimieren</s:String>
    <s:String x:Key="Tip_AlwaysOnTop">Immer im Vordergrund</s:String>
    <s:String x:Key="Tip_Settings">Einstellungen</s:String>
    <s:String x:Key="Tip_Menu">Menü</s:String>
    <s:String x:Key="Tip_MoreActions">Weitere Aktionen</s:String>
    <s:String x:Key="Tip_ShowHideCode">Code ein-/ausblenden</s:String>
    <s:String x:Key="Tip_CopyToClipboard">In Zwischenablage kopieren</s:String>
    <s:String x:Key="Tip_Exit">Beenden</s:String>

    <!-- Toolbar / buttons -->
    <s:String x:Key="Btn_Add">+ Hinzufügen</s:String>
    <s:String x:Key="Btn_Copy">Kopieren</s:String>
    <s:String x:Key="Btn_Unlock">Entsperren</s:String>
    <s:String x:Key="Btn_ClickToUnlock">Zum Entsperren klicken</s:String>
    <s:String x:Key="Btn_Browse">Durchsuchen...</s:String>
    <s:String x:Key="Btn_OK">OK</s:String>
    <s:String x:Key="Btn_Cancel">Abbrechen</s:String>
    <s:String x:Key="Btn_Save">Speichern</s:String>
    <s:String x:Key="Btn_Delete">Löschen</s:String>
    <s:String x:Key="Btn_Import">Importieren</s:String>
    <s:String x:Key="Btn_Export">Exportieren</s:String>
    <s:String x:Key="Btn_Password">Passwort</s:String>

    <!-- Hamburger menu -->
    <s:String x:Key="Menu_New">Neu</s:String>
    <s:String x:Key="Menu_Import">Importieren</s:String>
    <s:String x:Key="Menu_Export">Exportieren</s:String>
    <s:String x:Key="Menu_Password">Passwort</s:String>
    <s:String x:Key="Menu_Settings">Einstellungen</s:String>
    <s:String x:Key="Menu_Close">Schließen</s:String>
    <s:String x:Key="Menu_Exit">Beenden</s:String>

    <!-- Card context menu -->
    <s:String x:Key="Menu_Color">Farbe</s:String>
    <s:String x:Key="Menu_ResetColor">Zurücksetzen</s:String>
    <s:String x:Key="Menu_Rename">Umbenennen</s:String>
    <s:String x:Key="Menu_Delete">Löschen</s:String>

    <!-- System tray -->
    <s:String x:Key="Tray_Show">Anzeigen</s:String>
    <s:String x:Key="Tray_Exit">Beenden</s:String>

    <!-- Lock overlay -->
    <s:String x:Key="Lock_Title">Gesperrt</s:String>
    <s:String x:Key="Lock_EnterPassword">Passwort zum Entsperren eingeben:</s:String>
    <s:String x:Key="Lock_WrongPassword">Falsches Passwort.</s:String>

    <!-- Empty state -->
    <s:String x:Key="EmptyState">Noch keine Authenticatoren. Klicken Sie auf „+ Hinzufügen" oder „Importieren".</s:String>

    <!-- Toast -->
    <s:String x:Key="Toast_Copied">Kopiert!</s:String>

    <!-- Status messages -->
    <s:String x:Key="Status_Deleted">„{0}" gelöscht. Sicherung gespeichert.</s:String>
    <s:String x:Key="Status_SettingsSaved">Einstellungen gespeichert.</s:String>
    <s:String x:Key="Status_Imported">{0} Authenticator(en) importiert.</s:String>
    <s:String x:Key="Status_NoAuthFound">Keine Authenticatoren in der Datei gefunden.</s:String>
    <s:String x:Key="Status_NothingToExport">Nichts zum Exportieren vorhanden.</s:String>
    <s:String x:Key="Status_Exported">{0} Authenticator(en) exportiert.</s:String>
    <s:String x:Key="Status_PasswordRemoved">Passwortschutz entfernt.</s:String>
    <s:String x:Key="Status_PasswordUpdated">Passwortschutz aktualisiert.</s:String>

    <!-- Settings dialog -->
    <s:String x:Key="Settings_Title">Einstellungen</s:String>
    <s:String x:Key="Settings_DataFile">Datendatei-Speicherort:</s:String>
    <s:String x:Key="Settings_AutoLock">Automatische Sperre (Minuten, 0 = deaktiviert):</s:String>
    <s:String x:Key="Settings_Theme">Design:</s:String>
    <s:String x:Key="Settings_Dark">Dunkel</s:String>
    <s:String x:Key="Settings_Light">Hell</s:String>
    <s:String x:Key="Settings_Language">Sprache:</s:String>
    <s:String x:Key="Settings_Opacity">Fenstertransparenz:</s:String>
    <s:String x:Key="Settings_InvalidTimeout">Bitte geben Sie einen gültigen Wert ein (0–1440 Minuten).</s:String>
    <s:String x:Key="Settings_Hotkey">Globaler Hotkey (Anzeigen/Ausblenden):</s:String>
    <s:String x:Key="Settings_HotkeyClear">Löschen</s:String>
    <s:String x:Key="Settings_HotkeyHint">Tastenkombination drücken...</s:String>
    <s:String x:Key="Settings_HotkeyFailed">Hotkey-Registrierung fehlgeschlagen. Eine andere Anwendung verwendet möglicherweise diese Tastenkombination.</s:String>
    <s:String x:Key="Settings_StartMinimized">Beim Start in den Infobereich minimieren</s:String>

    <!-- Add authenticator dialog -->
    <s:String x:Key="Add_Title">Authenticator hinzufügen</s:String>
    <s:String x:Key="Add_Name">Name</s:String>
    <s:String x:Key="Add_SecretKey">Geheimer Schlüssel (Base32) oder otpauth:// URI</s:String>
    <s:String x:Key="Add_Algorithm">Algorithmus</s:String>
    <s:String x:Key="Add_Period">Intervall (Sek.)</s:String>
    <s:String x:Key="Add_Digits">Stellen</s:String>
    <s:String x:Key="Add_Preview">Vorschau</s:String>
    <s:String x:Key="Add_EnterName">Bitte geben Sie einen Namen ein.</s:String>
    <s:String x:Key="Add_EnterSecret">Bitte geben Sie einen geheimen Schlüssel ein.</s:String>
    <s:String x:Key="Add_InvalidSecret">Ungültiger Base32-Schlüssel.</s:String>
    <s:String x:Key="Add_InvalidPeriod">Das Intervall muss zwischen 10 und 300 Sekunden liegen.</s:String>
    <s:String x:Key="Add_InvalidDigits">Die Stellenanzahl muss zwischen 4 und 8 liegen.</s:String>
    <s:String x:Key="Add_Validation">Validierung</s:String>
    <s:String x:Key="Add_Preset">Vorlage</s:String>
    <s:String x:Key="Add_HintUseCustom">Wenn Ihr Dienst spezielle Einstellungen erfordert (nicht standardmäßiger Algorithmus, Intervall oder Stellenanzahl), wählen Sie „Benutzerdefiniert".</s:String>
    <s:String x:Key="Add_HintSHA1">Die meisten Dienste verwenden SHA-1. Ändern Sie dies nur, wenn Ihr Dienst etwas anderes vorgibt.</s:String>
    <s:String x:Key="Add_HintSHA256">SHA-256 wird von einigen Unternehmens- und Bankdiensten verwendet.</s:String>
    <s:String x:Key="Add_HintSHA512">SHA-512 wird selten verwendet. Prüfen Sie die Dokumentation Ihres Dienstes.</s:String>
    <s:String x:Key="Preset_Custom">Benutzerdefiniert</s:String>
    <s:String x:Key="Preset_Standard">Standard: Google, GitHub, Microsoft, Discord, Amazon, X usw.</s:String>

    <!-- Confirm delete dialog -->
    <s:String x:Key="Delete_Title">Löschen bestätigen</s:String>
    <s:String x:Key="Delete_Message">„{0}" löschen?</s:String>
    <s:String x:Key="Delete_TypeToConfirmPrefix">Geben Sie</s:String>
    <s:String x:Key="Delete_TypeToConfirmKeyword">delete me</s:String>
    <s:String x:Key="Delete_TypeToConfirmSuffix">zur Bestätigung ein:</s:String>

    <!-- Rename dialog -->
    <s:String x:Key="Rename_Title">Umbenennen</s:String>
    <s:String x:Key="Rename_Name">Name</s:String>

    <!-- Password dialog -->
    <s:String x:Key="Password_Title">Passwort</s:String>
    <s:String x:Key="Password_Label">Passwort</s:String>
    <s:String x:Key="Password_Confirm">Passwort bestätigen</s:String>
    <s:String x:Key="Password_EnterPassword">Bitte geben Sie ein Passwort ein.</s:String>
    <s:String x:Key="Password_DontMatch">Passwörter stimmen nicht überein.</s:String>
    <s:String x:Key="Password_Error">Fehler</s:String>

    <!-- Password dialog titles -->
    <s:String x:Key="PwTitle_WinAuth">WinAuth-Passwort eingeben</s:String>
    <s:String x:Key="PwTitle_FilePassword">Dateipasswort eingeben</s:String>
    <s:String x:Key="PwTitle_SetExport">Export-Passwort festlegen</s:String>
    <s:String x:Key="PwTitle_SetProtection">Passwortschutz festlegen</s:String>

    <!-- File dialogs -->
    <s:String x:Key="FileDialog_ImportTitle">Authenticatoren importieren</s:String>
    <s:String x:Key="FileDialog_ExportTitle">Authenticatoren exportieren</s:String>
    <s:String x:Key="FileDialog_ChooseLocation">Speicherort für Datendatei wählen</s:String>

    <!-- Error messages -->
    <s:String x:Key="Error_ImportFailed">Import fehlgeschlagen:</s:String>
    <s:String x:Key="Error_ExportFailed">Export fehlgeschlagen:</s:String>
    <s:String x:Key="Error_WrongPassword">Falsches Passwort.</s:String>
    <s:String x:Key="Error_ImportError">Importfehler</s:String>
    <s:String x:Key="Error_ExportError">Exportfehler</s:String>

</ResourceDictionary>
