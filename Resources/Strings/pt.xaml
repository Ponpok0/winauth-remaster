<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:s="clr-namespace:System;assembly=System.Runtime">

    <!-- Toolbar tooltips -->
    <s:String x:Key="Tip_MinimizeToTray">Minimizar para a bandeja</s:String>
    <s:String x:Key="Tip_AlwaysOnTop">Sempre visível</s:String>
    <s:String x:Key="Tip_Settings">Configurações</s:String>
    <s:String x:Key="Tip_Menu">Menu</s:String>
    <s:String x:Key="Tip_MoreActions">Mais ações</s:String>
    <s:String x:Key="Tip_ShowHideCode">Mostrar / Ocultar código</s:String>
    <s:String x:Key="Tip_CopyToClipboard">Copiar para a área de transferência</s:String>
    <s:String x:Key="Tip_Exit">Sair</s:String>

    <!-- Toolbar / buttons -->
    <s:String x:Key="Btn_Add">+ Adicionar</s:String>
    <s:String x:Key="Btn_Copy">Copiar</s:String>
    <s:String x:Key="Btn_Unlock">Desbloquear</s:String>
    <s:String x:Key="Btn_ClickToUnlock">Clique para desbloquear</s:String>
    <s:String x:Key="Btn_Browse">Procurar...</s:String>
    <s:String x:Key="Btn_OK">OK</s:String>
    <s:String x:Key="Btn_Cancel">Cancelar</s:String>
    <s:String x:Key="Btn_Save">Salvar</s:String>
    <s:String x:Key="Btn_Delete">Excluir</s:String>
    <s:String x:Key="Btn_Import">Importar</s:String>
    <s:String x:Key="Btn_Export">Exportar</s:String>
    <s:String x:Key="Btn_Password">Senha</s:String>

    <!-- Hamburger menu -->
    <s:String x:Key="Menu_New">Novo</s:String>
    <s:String x:Key="Menu_Import">Importar</s:String>
    <s:String x:Key="Menu_Export">Exportar</s:String>
    <s:String x:Key="Menu_Password">Senha</s:String>
    <s:String x:Key="Menu_Settings">Configurações</s:String>
    <s:String x:Key="Menu_Close">Fechar</s:String>
    <s:String x:Key="Menu_Exit">Sair</s:String>

    <!-- Card context menu -->
    <s:String x:Key="Menu_Color">Cor</s:String>
    <s:String x:Key="Menu_ResetColor">Redefinir</s:String>
    <s:String x:Key="Menu_Rename">Renomear</s:String>
    <s:String x:Key="Menu_Delete">Excluir</s:String>

    <!-- System tray -->
    <s:String x:Key="Tray_Show">Mostrar</s:String>
    <s:String x:Key="Tray_Exit">Sair</s:String>

    <!-- Lock overlay -->
    <s:String x:Key="Lock_Title">Bloqueado</s:String>
    <s:String x:Key="Lock_EnterPassword">Digite a senha para desbloquear:</s:String>
    <s:String x:Key="Lock_WrongPassword">Senha incorreta.</s:String>

    <!-- Empty state -->
    <s:String x:Key="EmptyState">Nenhum autenticador. Clique em «+ Adicionar» ou «Importar» para começar.</s:String>

    <!-- Toast -->
    <s:String x:Key="Toast_Copied">Copiado!</s:String>

    <!-- Status messages -->
    <s:String x:Key="Status_Deleted">«{0}» excluído. Backup salvo.</s:String>
    <s:String x:Key="Status_SettingsSaved">Configurações salvas.</s:String>
    <s:String x:Key="Status_Imported">{0} autenticador(es) importado(s).</s:String>
    <s:String x:Key="Status_NoAuthFound">Nenhum autenticador encontrado no arquivo.</s:String>
    <s:String x:Key="Status_NothingToExport">Nada para exportar.</s:String>
    <s:String x:Key="Status_Exported">{0} autenticador(es) exportado(s).</s:String>
    <s:String x:Key="Status_PasswordRemoved">Proteção por senha removida.</s:String>
    <s:String x:Key="Status_PasswordUpdated">Proteção por senha atualizada.</s:String>

    <!-- Settings dialog -->
    <s:String x:Key="Settings_Title">Configurações</s:String>
    <s:String x:Key="Settings_DataFile">Local do arquivo de dados:</s:String>
    <s:String x:Key="Settings_AutoLock">Bloqueio automático (minutos, 0 = desativado):</s:String>
    <s:String x:Key="Settings_Theme">Tema:</s:String>
    <s:String x:Key="Settings_Dark">Escuro</s:String>
    <s:String x:Key="Settings_Light">Claro</s:String>
    <s:String x:Key="Settings_Language">Idioma:</s:String>
    <s:String x:Key="Settings_Opacity">Opacidade da janela:</s:String>
    <s:String x:Key="Settings_InvalidTimeout">Insira um valor válido (0–1440 minutos).</s:String>
    <s:String x:Key="Settings_Hotkey">Atalho global (mostrar/ocultar):</s:String>
    <s:String x:Key="Settings_HotkeyClear">Limpar</s:String>
    <s:String x:Key="Settings_HotkeyHint">Pressione as teclas de atalho...</s:String>
    <s:String x:Key="Settings_HotkeyFailed">Falha ao registrar o atalho. Outro aplicativo pode estar usando esta combinação.</s:String>
    <s:String x:Key="Settings_StartMinimized">Iniciar minimizado na bandeja</s:String>

    <!-- Add authenticator dialog -->
    <s:String x:Key="Add_Title">Adicionar autenticador</s:String>
    <s:String x:Key="Add_Name">Nome</s:String>
    <s:String x:Key="Add_SecretKey">Chave secreta (Base32) ou URI otpauth://</s:String>
    <s:String x:Key="Add_Algorithm">Algoritmo</s:String>
    <s:String x:Key="Add_Period">Intervalo (seg.)</s:String>
    <s:String x:Key="Add_Digits">Dígitos</s:String>
    <s:String x:Key="Add_Preview">Visualizar</s:String>
    <s:String x:Key="Add_EnterName">Insira um nome.</s:String>
    <s:String x:Key="Add_EnterSecret">Insira uma chave secreta.</s:String>
    <s:String x:Key="Add_InvalidSecret">Chave Base32 inválida.</s:String>
    <s:String x:Key="Add_InvalidPeriod">O intervalo deve ser entre 10 e 300 segundos.</s:String>
    <s:String x:Key="Add_InvalidDigits">Os dígitos devem ser entre 4 e 8.</s:String>
    <s:String x:Key="Add_Validation">Validação</s:String>
    <s:String x:Key="Add_Preset">Predefinição</s:String>
    <s:String x:Key="Add_HintUseCustom">Se o seu serviço exigir configurações especiais (algoritmo, intervalo ou dígitos não padrão), selecione «Personalizado».</s:String>
    <s:String x:Key="Add_HintSHA1">A maioria dos serviços usa SHA-1. Altere apenas se o serviço exigir.</s:String>
    <s:String x:Key="Add_HintSHA256">SHA-256 é usado por alguns serviços empresariais e bancários.</s:String>
    <s:String x:Key="Add_HintSHA512">SHA-512 raramente é usado. Consulte a documentação do serviço.</s:String>
    <s:String x:Key="Preset_Custom">Personalizado</s:String>
    <s:String x:Key="Preset_Standard">Padrão: Google, GitHub, Microsoft, Discord, Amazon, X, etc.</s:String>

    <!-- Confirm delete dialog -->
    <s:String x:Key="Delete_Title">Confirmar exclusão</s:String>
    <s:String x:Key="Delete_Message">Excluir «{0}»?</s:String>
    <s:String x:Key="Delete_TypeToConfirmPrefix">Digite</s:String>
    <s:String x:Key="Delete_TypeToConfirmKeyword">delete me</s:String>
    <s:String x:Key="Delete_TypeToConfirmSuffix">para confirmar:</s:String>

    <!-- Rename dialog -->
    <s:String x:Key="Rename_Title">Renomear</s:String>
    <s:String x:Key="Rename_Name">Nome</s:String>

    <!-- Password dialog -->
    <s:String x:Key="Password_Title">Senha</s:String>
    <s:String x:Key="Password_Label">Senha</s:String>
    <s:String x:Key="Password_Confirm">Confirmar senha</s:String>
    <s:String x:Key="Password_EnterPassword">Insira uma senha.</s:String>
    <s:String x:Key="Password_DontMatch">As senhas não coincidem.</s:String>
    <s:String x:Key="Password_Error">Erro</s:String>

    <!-- Password dialog titles -->
    <s:String x:Key="PwTitle_WinAuth">Inserir senha do WinAuth</s:String>
    <s:String x:Key="PwTitle_FilePassword">Inserir senha do arquivo</s:String>
    <s:String x:Key="PwTitle_SetExport">Definir senha de exportação</s:String>
    <s:String x:Key="PwTitle_SetProtection">Definir proteção por senha</s:String>

    <!-- File dialogs -->
    <s:String x:Key="FileDialog_ImportTitle">Importar autenticadores</s:String>
    <s:String x:Key="FileDialog_ExportTitle">Exportar autenticadores</s:String>
    <s:String x:Key="FileDialog_ChooseLocation">Escolher local do arquivo de dados</s:String>

    <!-- Error messages -->
    <s:String x:Key="Error_ImportFailed">Falha na importação:</s:String>
    <s:String x:Key="Error_ExportFailed">Falha na exportação:</s:String>
    <s:String x:Key="Error_WrongPassword">Senha incorreta.</s:String>
    <s:String x:Key="Error_ImportError">Erro de importação</s:String>
    <s:String x:Key="Error_ExportError">Erro de exportação</s:String>

</ResourceDictionary>
