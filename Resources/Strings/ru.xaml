<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:s="clr-namespace:System;assembly=System.Runtime">

    <!-- Toolbar tooltips -->
    <s:String x:Key="Tip_MinimizeToTray">Свернуть в трей</s:String>
    <s:String x:Key="Tip_AlwaysOnTop">Поверх всех окон</s:String>
    <s:String x:Key="Tip_Settings">Настройки</s:String>
    <s:String x:Key="Tip_Menu">Меню</s:String>
    <s:String x:Key="Tip_MoreActions">Ещё</s:String>
    <s:String x:Key="Tip_ShowHideCode">Показать / Скрыть код</s:String>
    <s:String x:Key="Tip_CopyToClipboard">Копировать в буфер обмена</s:String>
    <s:String x:Key="Tip_Exit">Выход</s:String>

    <!-- Toolbar / buttons -->
    <s:String x:Key="Btn_Add">+ Добавить</s:String>
    <s:String x:Key="Btn_Copy">Копировать</s:String>
    <s:String x:Key="Btn_Unlock">Разблокировать</s:String>
    <s:String x:Key="Btn_ClickToUnlock">Нажмите для разблокировки</s:String>
    <s:String x:Key="Btn_Browse">Обзор...</s:String>
    <s:String x:Key="Btn_OK">ОК</s:String>
    <s:String x:Key="Btn_Cancel">Отмена</s:String>
    <s:String x:Key="Btn_Save">Сохранить</s:String>
    <s:String x:Key="Btn_Delete">Удалить</s:String>
    <s:String x:Key="Btn_Import">Импорт</s:String>
    <s:String x:Key="Btn_Export">Экспорт</s:String>
    <s:String x:Key="Btn_Password">Пароль</s:String>

    <!-- Hamburger menu -->
    <s:String x:Key="Menu_New">Создать</s:String>
    <s:String x:Key="Menu_Import">Импорт</s:String>
    <s:String x:Key="Menu_Export">Экспорт</s:String>
    <s:String x:Key="Menu_Password">Пароль</s:String>
    <s:String x:Key="Menu_Settings">Настройки</s:String>
    <s:String x:Key="Menu_Close">Закрыть</s:String>
    <s:String x:Key="Menu_Exit">Выход</s:String>

    <!-- Card context menu -->
    <s:String x:Key="Menu_Color">Цвет</s:String>
    <s:String x:Key="Menu_ResetColor">Сбросить</s:String>
    <s:String x:Key="Menu_Rename">Переименовать</s:String>
    <s:String x:Key="Menu_Delete">Удалить</s:String>

    <!-- System tray -->
    <s:String x:Key="Tray_Show">Показать</s:String>
    <s:String x:Key="Tray_Exit">Выход</s:String>

    <!-- Lock overlay -->
    <s:String x:Key="Lock_Title">Заблокировано</s:String>
    <s:String x:Key="Lock_EnterPassword">Введите пароль для разблокировки:</s:String>
    <s:String x:Key="Lock_WrongPassword">Неверный пароль.</s:String>

    <!-- Empty state -->
    <s:String x:Key="EmptyState">Нет аутентификаторов. Нажмите «+ Добавить» или «Импорт», чтобы начать.</s:String>

    <!-- Toast -->
    <s:String x:Key="Toast_Copied">Скопировано!</s:String>

    <!-- Status messages -->
    <s:String x:Key="Status_Deleted">«{0}» удалён. Резервная копия сохранена.</s:String>
    <s:String x:Key="Status_SettingsSaved">Настройки сохранены.</s:String>
    <s:String x:Key="Status_Imported">Импортировано аутентификаторов: {0}.</s:String>
    <s:String x:Key="Status_NoAuthFound">Аутентификаторы в файле не найдены.</s:String>
    <s:String x:Key="Status_NothingToExport">Нечего экспортировать.</s:String>
    <s:String x:Key="Status_Exported">Экспортировано аутентификаторов: {0}.</s:String>
    <s:String x:Key="Status_PasswordRemoved">Защита паролем снята.</s:String>
    <s:String x:Key="Status_PasswordUpdated">Защита паролем обновлена.</s:String>

    <!-- Settings dialog -->
    <s:String x:Key="Settings_Title">Настройки</s:String>
    <s:String x:Key="Settings_DataFile">Расположение файла данных:</s:String>
    <s:String x:Key="Settings_AutoLock">Автоблокировка (мин., 0 = отключено):</s:String>
    <s:String x:Key="Settings_Theme">Тема:</s:String>
    <s:String x:Key="Settings_Dark">Тёмная</s:String>
    <s:String x:Key="Settings_Light">Светлая</s:String>
    <s:String x:Key="Settings_Language">Язык:</s:String>
    <s:String x:Key="Settings_Opacity">Прозрачность окна:</s:String>
    <s:String x:Key="Settings_InvalidTimeout">Введите допустимое значение (0–1440 минут).</s:String>
    <s:String x:Key="Settings_Hotkey">Глобальная горячая клавиша (показать/скрыть):</s:String>
    <s:String x:Key="Settings_HotkeyClear">Очистить</s:String>
    <s:String x:Key="Settings_HotkeyHint">Нажмите сочетание клавиш...</s:String>
    <s:String x:Key="Settings_HotkeyFailed">Не удалось зарегистрировать горячую клавишу. Возможно, другое приложение использует это сочетание.</s:String>
    <s:String x:Key="Settings_StartMinimized">Запускать свёрнутым в трей</s:String>

    <!-- Add authenticator dialog -->
    <s:String x:Key="Add_Title">Добавить аутентификатор</s:String>
    <s:String x:Key="Add_Name">Название</s:String>
    <s:String x:Key="Add_SecretKey">Секретный ключ (Base32) или URI otpauth://</s:String>
    <s:String x:Key="Add_Algorithm">Алгоритм</s:String>
    <s:String x:Key="Add_Period">Интервал (сек.)</s:String>
    <s:String x:Key="Add_Digits">Цифры</s:String>
    <s:String x:Key="Add_Preview">Предпросмотр</s:String>
    <s:String x:Key="Add_EnterName">Введите название.</s:String>
    <s:String x:Key="Add_EnterSecret">Введите секретный ключ.</s:String>
    <s:String x:Key="Add_InvalidSecret">Недопустимый ключ Base32.</s:String>
    <s:String x:Key="Add_InvalidPeriod">Интервал должен быть от 10 до 300 секунд.</s:String>
    <s:String x:Key="Add_InvalidDigits">Количество цифр должно быть от 4 до 8.</s:String>
    <s:String x:Key="Add_Validation">Проверка</s:String>
    <s:String x:Key="Add_Preset">Шаблон</s:String>
    <s:String x:Key="Add_HintUseCustom">Если ваш сервис требует особых настроек (нестандартный алгоритм, интервал или количество цифр), выберите «Пользовательский».</s:String>
    <s:String x:Key="Add_HintSHA1">Большинство сервисов используют SHA-1. Изменяйте только по требованию сервиса.</s:String>
    <s:String x:Key="Add_HintSHA256">SHA-256 используется некоторыми корпоративными и банковскими сервисами.</s:String>
    <s:String x:Key="Add_HintSHA512">SHA-512 используется крайне редко. Проверьте документацию сервиса.</s:String>
    <s:String x:Key="Preset_Custom">Пользовательский</s:String>
    <s:String x:Key="Preset_Standard">Стандартный: Google, GitHub, Microsoft, Discord, Amazon, X и др.</s:String>

    <!-- Confirm delete dialog -->
    <s:String x:Key="Delete_Title">Подтверждение удаления</s:String>
    <s:String x:Key="Delete_Message">Удалить «{0}»?</s:String>
    <s:String x:Key="Delete_TypeToConfirmPrefix">Введите</s:String>
    <s:String x:Key="Delete_TypeToConfirmKeyword">delete me</s:String>
    <s:String x:Key="Delete_TypeToConfirmSuffix">для подтверждения:</s:String>

    <!-- Rename dialog -->
    <s:String x:Key="Rename_Title">Переименовать</s:String>
    <s:String x:Key="Rename_Name">Название</s:String>

    <!-- Password dialog -->
    <s:String x:Key="Password_Title">Пароль</s:String>
    <s:String x:Key="Password_Label">Пароль</s:String>
    <s:String x:Key="Password_Confirm">Подтверждение пароля</s:String>
    <s:String x:Key="Password_EnterPassword">Введите пароль.</s:String>
    <s:String x:Key="Password_DontMatch">Пароли не совпадают.</s:String>
    <s:String x:Key="Password_Error">Ошибка</s:String>

    <!-- Password dialog titles -->
    <s:String x:Key="PwTitle_WinAuth">Введите пароль WinAuth</s:String>
    <s:String x:Key="PwTitle_FilePassword">Введите пароль файла</s:String>
    <s:String x:Key="PwTitle_SetExport">Задать пароль экспорта</s:String>
    <s:String x:Key="PwTitle_SetProtection">Задать защиту паролем</s:String>

    <!-- File dialogs -->
    <s:String x:Key="FileDialog_ImportTitle">Импорт аутентификаторов</s:String>
    <s:String x:Key="FileDialog_ExportTitle">Экспорт аутентификаторов</s:String>
    <s:String x:Key="FileDialog_ChooseLocation">Выбрать расположение файла данных</s:String>

    <!-- Error messages -->
    <s:String x:Key="Error_ImportFailed">Ошибка импорта:</s:String>
    <s:String x:Key="Error_ExportFailed">Ошибка экспорта:</s:String>
    <s:String x:Key="Error_WrongPassword">Неверный пароль.</s:String>
    <s:String x:Key="Error_ImportError">Ошибка импорта</s:String>
    <s:String x:Key="Error_ExportError">Ошибка экспорта</s:String>

</ResourceDictionary>
