<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:s="clr-namespace:System;assembly=System.Runtime">

    <!-- Toolbar tooltips -->
    <s:String x:Key="Tip_MinimizeToTray">トレイに格納</s:String>
    <s:String x:Key="Tip_AlwaysOnTop">常に最前面</s:String>
    <s:String x:Key="Tip_Settings">設定</s:String>
    <s:String x:Key="Tip_Menu">メニュー</s:String>
    <s:String x:Key="Tip_MoreActions">操作</s:String>
    <s:String x:Key="Tip_ShowHideCode">コードの表示切替</s:String>
    <s:String x:Key="Tip_CopyToClipboard">クリップボードにコピー</s:String>
    <s:String x:Key="Tip_Exit">終了</s:String>

    <!-- Toolbar / buttons -->
    <s:String x:Key="Btn_Add">+ 追加</s:String>
    <s:String x:Key="Btn_Copy">コピー</s:String>
    <s:String x:Key="Btn_Unlock">解除</s:String>
    <s:String x:Key="Btn_ClickToUnlock">クリックして解除</s:String>
    <s:String x:Key="Btn_Browse">参照...</s:String>
    <s:String x:Key="Btn_OK">OK</s:String>
    <s:String x:Key="Btn_Cancel">キャンセル</s:String>
    <s:String x:Key="Btn_Save">保存</s:String>
    <s:String x:Key="Btn_Delete">削除</s:String>
    <s:String x:Key="Btn_Import">インポート</s:String>
    <s:String x:Key="Btn_Export">エクスポート</s:String>
    <s:String x:Key="Btn_Password">パスワード</s:String>

    <!-- Hamburger menu -->
    <s:String x:Key="Menu_New">新規作成</s:String>
    <s:String x:Key="Menu_Import">インポート</s:String>
    <s:String x:Key="Menu_Export">エクスポート</s:String>
    <s:String x:Key="Menu_Password">パスワード設定</s:String>
    <s:String x:Key="Menu_Settings">設定</s:String>
    <s:String x:Key="Menu_Close">閉じる</s:String>
    <s:String x:Key="Menu_Exit">終了</s:String>

    <!-- Card context menu -->
    <s:String x:Key="Menu_Color">カラー</s:String>
    <s:String x:Key="Menu_ResetColor">リセット</s:String>
    <s:String x:Key="Menu_Rename">名前を変更</s:String>
    <s:String x:Key="Menu_Delete">削除</s:String>

    <!-- System tray -->
    <s:String x:Key="Tray_Show">表示</s:String>
    <s:String x:Key="Tray_Exit">終了</s:String>

    <!-- Lock overlay -->
    <s:String x:Key="Lock_Title">ロック中</s:String>
    <s:String x:Key="Lock_EnterPassword">パスワードを入力して解除:</s:String>
    <s:String x:Key="Lock_WrongPassword">パスワードが違います。</s:String>

    <!-- Empty state -->
    <s:String x:Key="EmptyState">認証情報がありません。「+ 追加」または「インポート」で始めましょう。</s:String>

    <!-- Toast -->
    <s:String x:Key="Toast_Copied">コピーしました</s:String>

    <!-- Status messages -->
    <s:String x:Key="Status_Deleted">'{0}' を削除しました。バックアップを保存しました。</s:String>
    <s:String x:Key="Status_SettingsSaved">設定を保存しました。</s:String>
    <s:String x:Key="Status_Imported">{0} 件インポートしました。</s:String>
    <s:String x:Key="Status_NoAuthFound">認証情報が見つかりません。</s:String>
    <s:String x:Key="Status_NothingToExport">エクスポートするデータがありません。</s:String>
    <s:String x:Key="Status_Exported">{0} 件エクスポートしました。</s:String>
    <s:String x:Key="Status_PasswordRemoved">パスワード保護を解除しました。</s:String>
    <s:String x:Key="Status_PasswordUpdated">パスワード保護を更新しました。</s:String>

    <!-- Settings dialog -->
    <s:String x:Key="Settings_Title">設定</s:String>
    <s:String x:Key="Settings_DataFile">データファイルの場所:</s:String>
    <s:String x:Key="Settings_AutoLock">自動ロック (分、0 = 無効):</s:String>
    <s:String x:Key="Settings_Theme">テーマ:</s:String>
    <s:String x:Key="Settings_Dark">ダーク</s:String>
    <s:String x:Key="Settings_Light">ライト</s:String>
    <s:String x:Key="Settings_Language">言語:</s:String>
    <s:String x:Key="Settings_Opacity">ウィンドウの透過度:</s:String>
    <s:String x:Key="Settings_InvalidTimeout">有効なタイムアウト値を入力してください (0〜1440分)。</s:String>
    <s:String x:Key="Settings_Hotkey">グローバルホットキー（表示/非表示）:</s:String>
    <s:String x:Key="Settings_HotkeyClear">クリア</s:String>
    <s:String x:Key="Settings_HotkeyHint">ショートカットキーを押してください...</s:String>
    <s:String x:Key="Settings_HotkeyFailed">ホットキーの登録に失敗しました。他のアプリが同じショートカットを使用している可能性があります。</s:String>
    <s:String x:Key="Settings_StartMinimized">起動時にタスクトレイに格納</s:String>
    <s:String x:Key="Settings_StartWithWindows">Windows 起動時に自動起動</s:String>

    <!-- Add authenticator dialog -->
    <s:String x:Key="Add_Title">認証の追加</s:String>
    <s:String x:Key="Add_Name">名前</s:String>
    <s:String x:Key="Add_SecretKey">シークレットキー (Base32) または otpauth:// URI</s:String>
    <s:String x:Key="Add_Algorithm">アルゴリズム</s:String>
    <s:String x:Key="Add_Period">更新間隔 (秒)</s:String>
    <s:String x:Key="Add_Digits">桁数</s:String>
    <s:String x:Key="Add_Preview">プレビュー</s:String>
    <s:String x:Key="Add_EnterName">名前を入力してください。</s:String>
    <s:String x:Key="Add_EnterSecret">シークレットキーを入力してください。</s:String>
    <s:String x:Key="Add_InvalidSecret">無効なBase32シークレットキーです。</s:String>
    <s:String x:Key="Add_InvalidPeriod">更新間隔は10〜300秒で入力してください。</s:String>
    <s:String x:Key="Add_InvalidDigits">桁数は4〜8で入力してください。</s:String>
    <s:String x:Key="Add_Validation">入力エラー</s:String>
    <s:String x:Key="Add_Preset">プリセット</s:String>
    <s:String x:Key="Add_HintUseCustom">特殊な設定が必要なサービス（非標準のアルゴリズム・更新間隔・桁数）は「カスタム」を選択してください。</s:String>
    <s:String x:Key="Add_HintSHA1">ほとんどのサービスは SHA-1 を使用します。指定がない限り変更不要です。</s:String>
    <s:String x:Key="Add_HintSHA256">SHA-256 は一部の法人・金融系サービスで使用されています。</s:String>
    <s:String x:Key="Add_HintSHA512">SHA-512 はほぼ使われません。サービスのドキュメントを確認してください。</s:String>
    <s:String x:Key="Preset_Custom">カスタム</s:String>
    <s:String x:Key="Preset_Standard">標準: Google, GitHub, Microsoft, Discord, Amazon, X など</s:String>

    <!-- Confirm delete dialog -->
    <s:String x:Key="Delete_Title">削除の確認</s:String>
    <s:String x:Key="Delete_Message">'{0}' を削除しますか？</s:String>
    <s:String x:Key="Delete_TypeToConfirmPrefix"></s:String>
    <s:String x:Key="Delete_TypeToConfirmKeyword">delete me</s:String>
    <s:String x:Key="Delete_TypeToConfirmSuffix">と入力して確認:</s:String>

    <!-- Rename dialog -->
    <s:String x:Key="Rename_Title">名前の変更</s:String>
    <s:String x:Key="Rename_Name">名前</s:String>

    <!-- Password dialog -->
    <s:String x:Key="Password_Title">パスワード</s:String>
    <s:String x:Key="Password_Label">パスワード</s:String>
    <s:String x:Key="Password_Confirm">パスワードの確認</s:String>
    <s:String x:Key="Password_EnterPassword">パスワードを入力してください。</s:String>
    <s:String x:Key="Password_DontMatch">パスワードが一致しません。</s:String>
    <s:String x:Key="Password_Error">エラー</s:String>

    <!-- Password dialog titles -->
    <s:String x:Key="PwTitle_WinAuth">WinAuth パスワードを入力</s:String>
    <s:String x:Key="PwTitle_FilePassword">ファイルのパスワードを入力</s:String>
    <s:String x:Key="PwTitle_SetExport">エクスポートパスワードの設定</s:String>
    <s:String x:Key="PwTitle_SetProtection">パスワード保護の設定</s:String>

    <!-- File dialogs -->
    <s:String x:Key="FileDialog_ImportTitle">認証のインポート</s:String>
    <s:String x:Key="FileDialog_ExportTitle">認証のエクスポート</s:String>
    <s:String x:Key="FileDialog_ChooseLocation">データファイルの保存先を選択</s:String>

    <!-- Error messages -->
    <s:String x:Key="Error_ImportFailed">インポートに失敗しました:</s:String>
    <s:String x:Key="Error_ExportFailed">エクスポートに失敗しました:</s:String>
    <s:String x:Key="Error_WrongPassword">パスワードが違います。</s:String>
    <s:String x:Key="Error_ImportError">インポートエラー</s:String>
    <s:String x:Key="Error_ExportError">エクスポートエラー</s:String>

</ResourceDictionary>
