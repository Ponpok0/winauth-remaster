<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:s="clr-namespace:System;assembly=System.Runtime">

    <!-- Toolbar tooltips -->
    <s:String x:Key="Tip_MinimizeToTray">最小化到托盘</s:String>
    <s:String x:Key="Tip_AlwaysOnTop">置顶</s:String>
    <s:String x:Key="Tip_Settings">设置</s:String>
    <s:String x:Key="Tip_Menu">菜单</s:String>
    <s:String x:Key="Tip_MoreActions">更多操作</s:String>
    <s:String x:Key="Tip_ShowHideCode">显示 / 隐藏验证码</s:String>
    <s:String x:Key="Tip_CopyToClipboard">复制到剪贴板</s:String>
    <s:String x:Key="Tip_Exit">退出</s:String>

    <!-- Toolbar / buttons -->
    <s:String x:Key="Btn_Add">+ 添加</s:String>
    <s:String x:Key="Btn_Copy">复制</s:String>
    <s:String x:Key="Btn_Unlock">解锁</s:String>
    <s:String x:Key="Btn_ClickToUnlock">点击解锁</s:String>
    <s:String x:Key="Btn_Browse">浏览...</s:String>
    <s:String x:Key="Btn_OK">确定</s:String>
    <s:String x:Key="Btn_Cancel">取消</s:String>
    <s:String x:Key="Btn_Save">保存</s:String>
    <s:String x:Key="Btn_Delete">删除</s:String>
    <s:String x:Key="Btn_Import">导入</s:String>
    <s:String x:Key="Btn_Export">导出</s:String>
    <s:String x:Key="Btn_Password">密码</s:String>

    <!-- Hamburger menu -->
    <s:String x:Key="Menu_New">新建</s:String>
    <s:String x:Key="Menu_Import">导入</s:String>
    <s:String x:Key="Menu_Export">导出</s:String>
    <s:String x:Key="Menu_Password">密码设置</s:String>
    <s:String x:Key="Menu_Settings">设置</s:String>
    <s:String x:Key="Menu_Close">关闭</s:String>
    <s:String x:Key="Menu_Exit">退出</s:String>

    <!-- Card context menu -->
    <s:String x:Key="Menu_Color">颜色</s:String>
    <s:String x:Key="Menu_ResetColor">重置</s:String>
    <s:String x:Key="Menu_Rename">重命名</s:String>
    <s:String x:Key="Menu_Delete">删除</s:String>

    <!-- System tray -->
    <s:String x:Key="Tray_Show">显示</s:String>
    <s:String x:Key="Tray_Exit">退出</s:String>

    <!-- Lock overlay -->
    <s:String x:Key="Lock_Title">已锁定</s:String>
    <s:String x:Key="Lock_EnterPassword">输入密码以解锁：</s:String>
    <s:String x:Key="Lock_WrongPassword">密码错误。</s:String>

    <!-- Empty state -->
    <s:String x:Key="EmptyState">暂无验证器。点击"+ 添加"或"导入"开始使用。</s:String>

    <!-- Toast -->
    <s:String x:Key="Toast_Copied">已复制！</s:String>

    <!-- Status messages -->
    <s:String x:Key="Status_Deleted">已删除"{0}"。备份已保存。</s:String>
    <s:String x:Key="Status_SettingsSaved">设置已保存。</s:String>
    <s:String x:Key="Status_Imported">已导入 {0} 个验证器。</s:String>
    <s:String x:Key="Status_NoAuthFound">文件中未找到验证器。</s:String>
    <s:String x:Key="Status_NothingToExport">没有可导出的数据。</s:String>
    <s:String x:Key="Status_Exported">已导出 {0} 个验证器。</s:String>
    <s:String x:Key="Status_PasswordRemoved">已移除密码保护。</s:String>
    <s:String x:Key="Status_PasswordUpdated">已更新密码保护。</s:String>

    <!-- Settings dialog -->
    <s:String x:Key="Settings_Title">设置</s:String>
    <s:String x:Key="Settings_DataFile">数据文件位置：</s:String>
    <s:String x:Key="Settings_AutoLock">自动锁定超时（分钟，0 = 禁用）：</s:String>
    <s:String x:Key="Settings_Theme">主题：</s:String>
    <s:String x:Key="Settings_Dark">深色</s:String>
    <s:String x:Key="Settings_Light">浅色</s:String>
    <s:String x:Key="Settings_Language">语言：</s:String>
    <s:String x:Key="Settings_Opacity">窗口透明度：</s:String>
    <s:String x:Key="Settings_InvalidTimeout">请输入有效的超时值（0–1440 分钟）。</s:String>
    <s:String x:Key="Settings_Hotkey">全局热键（显示/隐藏）：</s:String>
    <s:String x:Key="Settings_HotkeyClear">清除</s:String>
    <s:String x:Key="Settings_HotkeyHint">请按快捷键...</s:String>
    <s:String x:Key="Settings_HotkeyFailed">热键注册失败。其他应用程序可能正在使用此快捷键。</s:String>

    <!-- Add authenticator dialog -->
    <s:String x:Key="Add_Title">添加验证器</s:String>
    <s:String x:Key="Add_Name">名称</s:String>
    <s:String x:Key="Add_SecretKey">密钥 (Base32) 或 otpauth:// URI</s:String>
    <s:String x:Key="Add_Algorithm">算法</s:String>
    <s:String x:Key="Add_Period">更新间隔（秒）</s:String>
    <s:String x:Key="Add_Digits">位数</s:String>
    <s:String x:Key="Add_Preview">预览</s:String>
    <s:String x:Key="Add_EnterName">请输入名称。</s:String>
    <s:String x:Key="Add_EnterSecret">请输入密钥。</s:String>
    <s:String x:Key="Add_InvalidSecret">无效的 Base32 密钥。</s:String>
    <s:String x:Key="Add_InvalidPeriod">更新间隔须在 10 到 300 秒之间。</s:String>
    <s:String x:Key="Add_InvalidDigits">位数须在 4 到 8 之间。</s:String>
    <s:String x:Key="Add_Validation">验证</s:String>
    <s:String x:Key="Add_Preset">预设</s:String>
    <s:String x:Key="Add_HintUseCustom">如果您的服务需要特殊设置（非标准算法、间隔或位数），请选择"自定义"。</s:String>
    <s:String x:Key="Add_HintSHA1">大多数服务使用 SHA-1。除非服务另有说明，否则无需更改。</s:String>
    <s:String x:Key="Add_HintSHA256">SHA-256 用于部分企业和银行服务。</s:String>
    <s:String x:Key="Add_HintSHA512">SHA-512 很少使用。请查看服务的相关文档。</s:String>
    <s:String x:Key="Preset_Custom">自定义</s:String>
    <s:String x:Key="Preset_Standard">标准：Google、GitHub、Microsoft、Discord、Amazon、X 等</s:String>

    <!-- Confirm delete dialog -->
    <s:String x:Key="Delete_Title">确认删除</s:String>
    <s:String x:Key="Delete_Message">确定要删除"{0}"吗？</s:String>
    <s:String x:Key="Delete_TypeToConfirmPrefix">输入</s:String>
    <s:String x:Key="Delete_TypeToConfirmKeyword">delete me</s:String>
    <s:String x:Key="Delete_TypeToConfirmSuffix">以确认：</s:String>

    <!-- Rename dialog -->
    <s:String x:Key="Rename_Title">重命名</s:String>
    <s:String x:Key="Rename_Name">名称</s:String>

    <!-- Password dialog -->
    <s:String x:Key="Password_Title">密码</s:String>
    <s:String x:Key="Password_Label">密码</s:String>
    <s:String x:Key="Password_Confirm">确认密码</s:String>
    <s:String x:Key="Password_EnterPassword">请输入密码。</s:String>
    <s:String x:Key="Password_DontMatch">密码不一致。</s:String>
    <s:String x:Key="Password_Error">错误</s:String>

    <!-- Password dialog titles -->
    <s:String x:Key="PwTitle_WinAuth">输入 WinAuth 密码</s:String>
    <s:String x:Key="PwTitle_FilePassword">输入文件密码</s:String>
    <s:String x:Key="PwTitle_SetExport">设置导出密码</s:String>
    <s:String x:Key="PwTitle_SetProtection">设置密码保护</s:String>

    <!-- File dialogs -->
    <s:String x:Key="FileDialog_ImportTitle">导入验证器</s:String>
    <s:String x:Key="FileDialog_ExportTitle">导出验证器</s:String>
    <s:String x:Key="FileDialog_ChooseLocation">选择数据文件位置</s:String>

    <!-- Error messages -->
    <s:String x:Key="Error_ImportFailed">导入失败：</s:String>
    <s:String x:Key="Error_ExportFailed">导出失败：</s:String>
    <s:String x:Key="Error_WrongPassword">密码错误。</s:String>
    <s:String x:Key="Error_ImportError">导入错误</s:String>
    <s:String x:Key="Error_ExportError">导出错误</s:String>

</ResourceDictionary>
