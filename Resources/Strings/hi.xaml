<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:s="clr-namespace:System;assembly=System.Runtime">

    <!-- Toolbar tooltips -->
    <s:String x:Key="Tip_MinimizeToTray">ट्रे में छोटा करें</s:String>
    <s:String x:Key="Tip_AlwaysOnTop">हमेशा सबसे ऊपर</s:String>
    <s:String x:Key="Tip_Settings">सेटिंग्स</s:String>
    <s:String x:Key="Tip_Menu">मेनू</s:String>
    <s:String x:Key="Tip_MoreActions">और विकल्प</s:String>
    <s:String x:Key="Tip_ShowHideCode">कोड दिखाएँ / छिपाएँ</s:String>
    <s:String x:Key="Tip_CopyToClipboard">क्लिपबोर्ड में कॉपी करें</s:String>
    <s:String x:Key="Tip_Exit">बाहर निकलें</s:String>

    <!-- Toolbar / buttons -->
    <s:String x:Key="Btn_Add">+ जोड़ें</s:String>
    <s:String x:Key="Btn_Copy">कॉपी</s:String>
    <s:String x:Key="Btn_Unlock">अनलॉक</s:String>
    <s:String x:Key="Btn_ClickToUnlock">अनलॉक करने के लिए क्लिक करें</s:String>
    <s:String x:Key="Btn_Browse">ब्राउज़ करें...</s:String>
    <s:String x:Key="Btn_OK">ठीक है</s:String>
    <s:String x:Key="Btn_Cancel">रद्द करें</s:String>
    <s:String x:Key="Btn_Save">सहेजें</s:String>
    <s:String x:Key="Btn_Delete">हटाएँ</s:String>
    <s:String x:Key="Btn_Import">आयात</s:String>
    <s:String x:Key="Btn_Export">निर्यात</s:String>
    <s:String x:Key="Btn_Password">पासवर्ड</s:String>

    <!-- Hamburger menu -->
    <s:String x:Key="Menu_New">नया</s:String>
    <s:String x:Key="Menu_Import">आयात</s:String>
    <s:String x:Key="Menu_Export">निर्यात</s:String>
    <s:String x:Key="Menu_Password">पासवर्ड</s:String>
    <s:String x:Key="Menu_Settings">सेटिंग्स</s:String>
    <s:String x:Key="Menu_Close">बंद करें</s:String>
    <s:String x:Key="Menu_Exit">बाहर निकलें</s:String>

    <!-- Card context menu -->
    <s:String x:Key="Menu_Color">रंग</s:String>
    <s:String x:Key="Menu_ResetColor">रीसेट</s:String>
    <s:String x:Key="Menu_Rename">नाम बदलें</s:String>
    <s:String x:Key="Menu_Delete">हटाएँ</s:String>

    <!-- System tray -->
    <s:String x:Key="Tray_Show">दिखाएँ</s:String>
    <s:String x:Key="Tray_Exit">बाहर निकलें</s:String>

    <!-- Lock overlay -->
    <s:String x:Key="Lock_Title">लॉक है</s:String>
    <s:String x:Key="Lock_EnterPassword">अनलॉक करने के लिए पासवर्ड दर्ज करें:</s:String>
    <s:String x:Key="Lock_WrongPassword">गलत पासवर्ड।</s:String>

    <!-- Empty state -->
    <s:String x:Key="EmptyState">कोई ऑथेंटिकेटर नहीं है। शुरू करने के लिए '+ जोड़ें' या 'आयात' पर क्लिक करें।</s:String>

    <!-- Toast -->
    <s:String x:Key="Toast_Copied">कॉपी हो गया!</s:String>

    <!-- Status messages -->
    <s:String x:Key="Status_Deleted">'{0}' हटाया गया। बैकअप सहेजा गया।</s:String>
    <s:String x:Key="Status_SettingsSaved">सेटिंग्स सहेजी गईं।</s:String>
    <s:String x:Key="Status_Imported">{0} ऑथेंटिकेटर आयात किए गए।</s:String>
    <s:String x:Key="Status_NoAuthFound">फ़ाइल में कोई ऑथेंटिकेटर नहीं मिला।</s:String>
    <s:String x:Key="Status_NothingToExport">निर्यात करने के लिए कुछ नहीं है।</s:String>
    <s:String x:Key="Status_Exported">{0} ऑथेंटिकेटर निर्यात किए गए।</s:String>
    <s:String x:Key="Status_PasswordRemoved">पासवर्ड सुरक्षा हटाई गई।</s:String>
    <s:String x:Key="Status_PasswordUpdated">पासवर्ड सुरक्षा अपडेट की गई।</s:String>

    <!-- Settings dialog -->
    <s:String x:Key="Settings_Title">सेटिंग्स</s:String>
    <s:String x:Key="Settings_DataFile">डेटा फ़ाइल का स्थान:</s:String>
    <s:String x:Key="Settings_AutoLock">ऑटो-लॉक समय (मिनट, 0 = अक्षम):</s:String>
    <s:String x:Key="Settings_Theme">थीम:</s:String>
    <s:String x:Key="Settings_Dark">डार्क</s:String>
    <s:String x:Key="Settings_Light">लाइट</s:String>
    <s:String x:Key="Settings_Language">भाषा:</s:String>
    <s:String x:Key="Settings_Opacity">विंडो पारदर्शिता:</s:String>
    <s:String x:Key="Settings_InvalidTimeout">कृपया एक मान्य मान दर्ज करें (0–1440 मिनट)।</s:String>
    <s:String x:Key="Settings_Hotkey">ग्लोबल हॉटकी (दिखाएँ/छिपाएँ):</s:String>
    <s:String x:Key="Settings_HotkeyClear">साफ़ करें</s:String>
    <s:String x:Key="Settings_HotkeyHint">शॉर्टकट कुंजियाँ दबाएँ...</s:String>
    <s:String x:Key="Settings_HotkeyFailed">हॉटकी पंजीकरण विफल। कोई अन्य ऐप इस शॉर्टकट का उपयोग कर रहा हो सकता है।</s:String>
    <s:String x:Key="Settings_StartMinimized">ट्रे में छोटा करके शुरू करें</s:String>

    <!-- Add authenticator dialog -->
    <s:String x:Key="Add_Title">ऑथेंटिकेटर जोड़ें</s:String>
    <s:String x:Key="Add_Name">नाम</s:String>
    <s:String x:Key="Add_SecretKey">गुप्त कुंजी (Base32) या otpauth:// URI</s:String>
    <s:String x:Key="Add_Algorithm">एल्गोरिथम</s:String>
    <s:String x:Key="Add_Period">अंतराल (सेकंड)</s:String>
    <s:String x:Key="Add_Digits">अंक</s:String>
    <s:String x:Key="Add_Preview">पूर्वावलोकन</s:String>
    <s:String x:Key="Add_EnterName">कृपया एक नाम दर्ज करें।</s:String>
    <s:String x:Key="Add_EnterSecret">कृपया एक गुप्त कुंजी दर्ज करें।</s:String>
    <s:String x:Key="Add_InvalidSecret">अमान्य Base32 गुप्त कुंजी।</s:String>
    <s:String x:Key="Add_InvalidPeriod">अंतराल 10 से 300 सेकंड के बीच होना चाहिए।</s:String>
    <s:String x:Key="Add_InvalidDigits">अंकों की संख्या 4 से 8 के बीच होनी चाहिए।</s:String>
    <s:String x:Key="Add_Validation">सत्यापन</s:String>
    <s:String x:Key="Add_Preset">प्रीसेट</s:String>
    <s:String x:Key="Add_HintUseCustom">यदि आपकी सेवा को विशेष सेटिंग्स (गैर-मानक एल्गोरिथम, अंतराल या अंक) की आवश्यकता है, तो "कस्टम" चुनें।</s:String>
    <s:String x:Key="Add_HintSHA1">अधिकांश सेवाएँ SHA-1 का उपयोग करती हैं। केवल तभी बदलें जब आपकी सेवा अन्यथा निर्दिष्ट करे।</s:String>
    <s:String x:Key="Add_HintSHA256">SHA-256 कुछ एंटरप्राइज़ और बैंकिंग सेवाओं द्वारा उपयोग किया जाता है।</s:String>
    <s:String x:Key="Add_HintSHA512">SHA-512 बहुत कम उपयोग होता है। अपनी सेवा का दस्तावेज़ देखें।</s:String>
    <s:String x:Key="Preset_Custom">कस्टम</s:String>
    <s:String x:Key="Preset_Standard">मानक: Google, GitHub, Microsoft, Discord, Amazon, X आदि</s:String>

    <!-- Confirm delete dialog -->
    <s:String x:Key="Delete_Title">हटाने की पुष्टि</s:String>
    <s:String x:Key="Delete_Message">'{0}' हटाएँ?</s:String>
    <s:String x:Key="Delete_TypeToConfirmPrefix">पुष्टि के लिए</s:String>
    <s:String x:Key="Delete_TypeToConfirmKeyword">delete me</s:String>
    <s:String x:Key="Delete_TypeToConfirmSuffix">टाइप करें:</s:String>

    <!-- Rename dialog -->
    <s:String x:Key="Rename_Title">नाम बदलें</s:String>
    <s:String x:Key="Rename_Name">नाम</s:String>

    <!-- Password dialog -->
    <s:String x:Key="Password_Title">पासवर्ड</s:String>
    <s:String x:Key="Password_Label">पासवर्ड</s:String>
    <s:String x:Key="Password_Confirm">पासवर्ड की पुष्टि</s:String>
    <s:String x:Key="Password_EnterPassword">कृपया पासवर्ड दर्ज करें।</s:String>
    <s:String x:Key="Password_DontMatch">पासवर्ड मेल नहीं खाते।</s:String>
    <s:String x:Key="Password_Error">त्रुटि</s:String>

    <!-- Password dialog titles -->
    <s:String x:Key="PwTitle_WinAuth">WinAuth पासवर्ड दर्ज करें</s:String>
    <s:String x:Key="PwTitle_FilePassword">फ़ाइल पासवर्ड दर्ज करें</s:String>
    <s:String x:Key="PwTitle_SetExport">निर्यात पासवर्ड सेट करें</s:String>
    <s:String x:Key="PwTitle_SetProtection">पासवर्ड सुरक्षा सेट करें</s:String>

    <!-- File dialogs -->
    <s:String x:Key="FileDialog_ImportTitle">ऑथेंटिकेटर आयात करें</s:String>
    <s:String x:Key="FileDialog_ExportTitle">ऑथेंटिकेटर निर्यात करें</s:String>
    <s:String x:Key="FileDialog_ChooseLocation">डेटा फ़ाइल का स्थान चुनें</s:String>

    <!-- Error messages -->
    <s:String x:Key="Error_ImportFailed">आयात विफल:</s:String>
    <s:String x:Key="Error_ExportFailed">निर्यात विफल:</s:String>
    <s:String x:Key="Error_WrongPassword">गलत पासवर्ड।</s:String>
    <s:String x:Key="Error_ImportError">आयात त्रुटि</s:String>
    <s:String x:Key="Error_ExportError">निर्यात त्रुटि</s:String>

</ResourceDictionary>
