<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:s="clr-namespace:System;assembly=System.Runtime">

    <!-- Toolbar tooltips -->
    <s:String x:Key="Tip_MinimizeToTray">Minimizar a la bandeja</s:String>
    <s:String x:Key="Tip_AlwaysOnTop">Siempre visible</s:String>
    <s:String x:Key="Tip_Settings">Configuración</s:String>
    <s:String x:Key="Tip_Menu">Menú</s:String>
    <s:String x:Key="Tip_MoreActions">Más acciones</s:String>
    <s:String x:Key="Tip_ShowHideCode">Mostrar / Ocultar código</s:String>
    <s:String x:Key="Tip_CopyToClipboard">Copiar al portapapeles</s:String>
    <s:String x:Key="Tip_Exit">Salir</s:String>

    <!-- Toolbar / buttons -->
    <s:String x:Key="Btn_Add">+ Agregar</s:String>
    <s:String x:Key="Btn_Copy">Copiar</s:String>
    <s:String x:Key="Btn_Unlock">Desbloquear</s:String>
    <s:String x:Key="Btn_ClickToUnlock">Clic para desbloquear</s:String>
    <s:String x:Key="Btn_Browse">Examinar...</s:String>
    <s:String x:Key="Btn_OK">Aceptar</s:String>
    <s:String x:Key="Btn_Cancel">Cancelar</s:String>
    <s:String x:Key="Btn_Save">Guardar</s:String>
    <s:String x:Key="Btn_Delete">Eliminar</s:String>
    <s:String x:Key="Btn_Import">Importar</s:String>
    <s:String x:Key="Btn_Export">Exportar</s:String>
    <s:String x:Key="Btn_Password">Contraseña</s:String>

    <!-- Hamburger menu -->
    <s:String x:Key="Menu_New">Nuevo</s:String>
    <s:String x:Key="Menu_Import">Importar</s:String>
    <s:String x:Key="Menu_Export">Exportar</s:String>
    <s:String x:Key="Menu_Password">Contraseña</s:String>
    <s:String x:Key="Menu_Settings">Configuración</s:String>
    <s:String x:Key="Menu_Close">Cerrar</s:String>
    <s:String x:Key="Menu_Exit">Salir</s:String>

    <!-- Card context menu -->
    <s:String x:Key="Menu_Color">Color</s:String>
    <s:String x:Key="Menu_ResetColor">Restablecer</s:String>
    <s:String x:Key="Menu_Rename">Cambiar nombre</s:String>
    <s:String x:Key="Menu_Delete">Eliminar</s:String>

    <!-- System tray -->
    <s:String x:Key="Tray_Show">Mostrar</s:String>
    <s:String x:Key="Tray_Exit">Salir</s:String>

    <!-- Lock overlay -->
    <s:String x:Key="Lock_Title">Bloqueado</s:String>
    <s:String x:Key="Lock_EnterPassword">Ingrese la contraseña para desbloquear:</s:String>
    <s:String x:Key="Lock_WrongPassword">Contraseña incorrecta.</s:String>

    <!-- Empty state -->
    <s:String x:Key="EmptyState">No hay autenticadores. Haga clic en «+ Agregar» o «Importar» para comenzar.</s:String>

    <!-- Toast -->
    <s:String x:Key="Toast_Copied">¡Copiado!</s:String>

    <!-- Status messages -->
    <s:String x:Key="Status_Deleted">Se eliminó «{0}». Copia de seguridad guardada.</s:String>
    <s:String x:Key="Status_SettingsSaved">Configuración guardada.</s:String>
    <s:String x:Key="Status_Imported">{0} autenticador(es) importado(s).</s:String>
    <s:String x:Key="Status_NoAuthFound">No se encontraron autenticadores en el archivo.</s:String>
    <s:String x:Key="Status_NothingToExport">No hay datos para exportar.</s:String>
    <s:String x:Key="Status_Exported">{0} autenticador(es) exportado(s).</s:String>
    <s:String x:Key="Status_PasswordRemoved">Protección con contraseña eliminada.</s:String>
    <s:String x:Key="Status_PasswordUpdated">Protección con contraseña actualizada.</s:String>

    <!-- Settings dialog -->
    <s:String x:Key="Settings_Title">Configuración</s:String>
    <s:String x:Key="Settings_DataFile">Ubicación del archivo de datos:</s:String>
    <s:String x:Key="Settings_AutoLock">Bloqueo automático (minutos, 0 = desactivado):</s:String>
    <s:String x:Key="Settings_Theme">Tema:</s:String>
    <s:String x:Key="Settings_Dark">Oscuro</s:String>
    <s:String x:Key="Settings_Light">Claro</s:String>
    <s:String x:Key="Settings_Language">Idioma:</s:String>
    <s:String x:Key="Settings_Opacity">Opacidad de la ventana:</s:String>
    <s:String x:Key="Settings_InvalidTimeout">Ingrese un valor válido (0–1440 minutos).</s:String>
    <s:String x:Key="Settings_Hotkey">Atajo global (mostrar/ocultar):</s:String>
    <s:String x:Key="Settings_HotkeyClear">Borrar</s:String>
    <s:String x:Key="Settings_HotkeyHint">Pulse las teclas de atajo...</s:String>
    <s:String x:Key="Settings_HotkeyFailed">Error al registrar el atajo. Otra aplicación puede estar usando esta combinación.</s:String>
    <s:String x:Key="Settings_StartMinimized">Iniciar minimizado en la bandeja</s:String>
    <s:String x:Key="Settings_StartWithWindows">Iniciar con Windows</s:String>

    <!-- Add authenticator dialog -->
    <s:String x:Key="Add_Title">Agregar autenticador</s:String>
    <s:String x:Key="Add_Name">Nombre</s:String>
    <s:String x:Key="Add_SecretKey">Clave secreta (Base32) o URI otpauth://</s:String>
    <s:String x:Key="Add_Algorithm">Algoritmo</s:String>
    <s:String x:Key="Add_Period">Intervalo (seg.)</s:String>
    <s:String x:Key="Add_Digits">Dígitos</s:String>
    <s:String x:Key="Add_Preview">Vista previa</s:String>
    <s:String x:Key="Add_EnterName">Ingrese un nombre.</s:String>
    <s:String x:Key="Add_EnterSecret">Ingrese una clave secreta.</s:String>
    <s:String x:Key="Add_InvalidSecret">Clave Base32 no válida.</s:String>
    <s:String x:Key="Add_InvalidPeriod">El intervalo debe ser entre 10 y 300 segundos.</s:String>
    <s:String x:Key="Add_InvalidDigits">Los dígitos deben ser entre 4 y 8.</s:String>
    <s:String x:Key="Add_Validation">Validación</s:String>
    <s:String x:Key="Add_Preset">Preajuste</s:String>
    <s:String x:Key="Add_HintUseCustom">Si su servicio requiere configuraciones especiales (algoritmo, intervalo o dígitos no estándar), seleccione «Personalizado».</s:String>
    <s:String x:Key="Add_HintSHA1">La mayoría de los servicios usan SHA-1. Cambie solo si su servicio lo indica.</s:String>
    <s:String x:Key="Add_HintSHA256">SHA-256 es utilizado por algunos servicios empresariales y bancarios.</s:String>
    <s:String x:Key="Add_HintSHA512">SHA-512 se usa raramente. Consulte la documentación de su servicio.</s:String>
    <s:String x:Key="Preset_Custom">Personalizado</s:String>
    <s:String x:Key="Preset_Standard">Estándar: Google, GitHub, Microsoft, Discord, Amazon, X, etc.</s:String>

    <!-- Confirm delete dialog -->
    <s:String x:Key="Delete_Title">Confirmar eliminación</s:String>
    <s:String x:Key="Delete_Message">¿Eliminar «{0}»?</s:String>
    <s:String x:Key="Delete_TypeToConfirmPrefix">Escriba</s:String>
    <s:String x:Key="Delete_TypeToConfirmKeyword">delete me</s:String>
    <s:String x:Key="Delete_TypeToConfirmSuffix">para confirmar:</s:String>

    <!-- Rename dialog -->
    <s:String x:Key="Rename_Title">Cambiar nombre</s:String>
    <s:String x:Key="Rename_Name">Nombre</s:String>

    <!-- Password dialog -->
    <s:String x:Key="Password_Title">Contraseña</s:String>
    <s:String x:Key="Password_Label">Contraseña</s:String>
    <s:String x:Key="Password_Confirm">Confirmar contraseña</s:String>
    <s:String x:Key="Password_EnterPassword">Ingrese una contraseña.</s:String>
    <s:String x:Key="Password_DontMatch">Las contraseñas no coinciden.</s:String>
    <s:String x:Key="Password_Error">Error</s:String>

    <!-- Password dialog titles -->
    <s:String x:Key="PwTitle_WinAuth">Ingrese la contraseña de WinAuth</s:String>
    <s:String x:Key="PwTitle_FilePassword">Ingrese la contraseña del archivo</s:String>
    <s:String x:Key="PwTitle_SetExport">Establecer contraseña de exportación</s:String>
    <s:String x:Key="PwTitle_SetProtection">Establecer protección con contraseña</s:String>

    <!-- File dialogs -->
    <s:String x:Key="FileDialog_ImportTitle">Importar autenticadores</s:String>
    <s:String x:Key="FileDialog_ExportTitle">Exportar autenticadores</s:String>
    <s:String x:Key="FileDialog_ChooseLocation">Elegir ubicación del archivo de datos</s:String>

    <!-- Error messages -->
    <s:String x:Key="Error_ImportFailed">Error en la importación:</s:String>
    <s:String x:Key="Error_ExportFailed">Error en la exportación:</s:String>
    <s:String x:Key="Error_WrongPassword">Contraseña incorrecta.</s:String>
    <s:String x:Key="Error_ImportError">Error de importación</s:String>
    <s:String x:Key="Error_ExportError">Error de exportación</s:String>

</ResourceDictionary>
