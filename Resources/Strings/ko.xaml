<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:s="clr-namespace:System;assembly=System.Runtime">

    <!-- Toolbar tooltips -->
    <s:String x:Key="Tip_MinimizeToTray">트레이로 최소화</s:String>
    <s:String x:Key="Tip_AlwaysOnTop">항상 위에</s:String>
    <s:String x:Key="Tip_Settings">설정</s:String>
    <s:String x:Key="Tip_Menu">메뉴</s:String>
    <s:String x:Key="Tip_MoreActions">추가 작업</s:String>
    <s:String x:Key="Tip_ShowHideCode">코드 표시 / 숨기기</s:String>
    <s:String x:Key="Tip_CopyToClipboard">클립보드에 복사</s:String>
    <s:String x:Key="Tip_Exit">종료</s:String>

    <!-- Toolbar / buttons -->
    <s:String x:Key="Btn_Add">+ 추가</s:String>
    <s:String x:Key="Btn_Copy">복사</s:String>
    <s:String x:Key="Btn_Unlock">잠금 해제</s:String>
    <s:String x:Key="Btn_ClickToUnlock">클릭하여 잠금 해제</s:String>
    <s:String x:Key="Btn_Browse">찾아보기...</s:String>
    <s:String x:Key="Btn_OK">확인</s:String>
    <s:String x:Key="Btn_Cancel">취소</s:String>
    <s:String x:Key="Btn_Save">저장</s:String>
    <s:String x:Key="Btn_Delete">삭제</s:String>
    <s:String x:Key="Btn_Import">가져오기</s:String>
    <s:String x:Key="Btn_Export">내보내기</s:String>
    <s:String x:Key="Btn_Password">비밀번호</s:String>

    <!-- Hamburger menu -->
    <s:String x:Key="Menu_New">새로 만들기</s:String>
    <s:String x:Key="Menu_Import">가져오기</s:String>
    <s:String x:Key="Menu_Export">내보내기</s:String>
    <s:String x:Key="Menu_Password">비밀번호 설정</s:String>
    <s:String x:Key="Menu_Settings">설정</s:String>
    <s:String x:Key="Menu_Close">닫기</s:String>
    <s:String x:Key="Menu_Exit">종료</s:String>

    <!-- Card context menu -->
    <s:String x:Key="Menu_Color">색상</s:String>
    <s:String x:Key="Menu_ResetColor">초기화</s:String>
    <s:String x:Key="Menu_Rename">이름 변경</s:String>
    <s:String x:Key="Menu_Delete">삭제</s:String>

    <!-- System tray -->
    <s:String x:Key="Tray_Show">표시</s:String>
    <s:String x:Key="Tray_Exit">종료</s:String>

    <!-- Lock overlay -->
    <s:String x:Key="Lock_Title">잠김</s:String>
    <s:String x:Key="Lock_EnterPassword">비밀번호를 입력하여 잠금 해제:</s:String>
    <s:String x:Key="Lock_WrongPassword">비밀번호가 올바르지 않습니다.</s:String>

    <!-- Empty state -->
    <s:String x:Key="EmptyState">인증기가 없습니다. '+ 추가' 또는 '가져오기'로 시작하세요.</s:String>

    <!-- Toast -->
    <s:String x:Key="Toast_Copied">복사됨!</s:String>

    <!-- Status messages -->
    <s:String x:Key="Status_Deleted">'{0}'을(를) 삭제했습니다. 백업이 저장되었습니다.</s:String>
    <s:String x:Key="Status_SettingsSaved">설정이 저장되었습니다.</s:String>
    <s:String x:Key="Status_Imported">{0}개의 인증기를 가져왔습니다.</s:String>
    <s:String x:Key="Status_NoAuthFound">파일에서 인증기를 찾을 수 없습니다.</s:String>
    <s:String x:Key="Status_NothingToExport">내보낼 데이터가 없습니다.</s:String>
    <s:String x:Key="Status_Exported">{0}개의 인증기를 내보냈습니다.</s:String>
    <s:String x:Key="Status_PasswordRemoved">비밀번호 보호가 해제되었습니다.</s:String>
    <s:String x:Key="Status_PasswordUpdated">비밀번호 보호가 업데이트되었습니다.</s:String>

    <!-- Settings dialog -->
    <s:String x:Key="Settings_Title">설정</s:String>
    <s:String x:Key="Settings_DataFile">데이터 파일 위치:</s:String>
    <s:String x:Key="Settings_AutoLock">자동 잠금 시간 (분, 0 = 비활성화):</s:String>
    <s:String x:Key="Settings_Theme">테마:</s:String>
    <s:String x:Key="Settings_Dark">다크</s:String>
    <s:String x:Key="Settings_Light">라이트</s:String>
    <s:String x:Key="Settings_Language">언어:</s:String>
    <s:String x:Key="Settings_Opacity">창 투명도:</s:String>
    <s:String x:Key="Settings_InvalidTimeout">유효한 시간 값을 입력하세요 (0–1440분).</s:String>
    <s:String x:Key="Settings_Hotkey">글로벌 단축키 (표시/숨기기):</s:String>
    <s:String x:Key="Settings_HotkeyClear">지우기</s:String>
    <s:String x:Key="Settings_HotkeyHint">단축키를 누르세요...</s:String>
    <s:String x:Key="Settings_HotkeyFailed">단축키 등록에 실패했습니다. 다른 앱이 같은 단축키를 사용 중일 수 있습니다.</s:String>
    <s:String x:Key="Settings_StartMinimized">시작 시 트레이로 최소화</s:String>

    <!-- Add authenticator dialog -->
    <s:String x:Key="Add_Title">인증기 추가</s:String>
    <s:String x:Key="Add_Name">이름</s:String>
    <s:String x:Key="Add_SecretKey">비밀 키 (Base32) 또는 otpauth:// URI</s:String>
    <s:String x:Key="Add_Algorithm">알고리즘</s:String>
    <s:String x:Key="Add_Period">갱신 간격 (초)</s:String>
    <s:String x:Key="Add_Digits">자릿수</s:String>
    <s:String x:Key="Add_Preview">미리 보기</s:String>
    <s:String x:Key="Add_EnterName">이름을 입력하세요.</s:String>
    <s:String x:Key="Add_EnterSecret">비밀 키를 입력하세요.</s:String>
    <s:String x:Key="Add_InvalidSecret">유효하지 않은 Base32 비밀 키입니다.</s:String>
    <s:String x:Key="Add_InvalidPeriod">갱신 간격은 10~300초여야 합니다.</s:String>
    <s:String x:Key="Add_InvalidDigits">자릿수는 4~8이어야 합니다.</s:String>
    <s:String x:Key="Add_Validation">유효성 검사</s:String>
    <s:String x:Key="Add_Preset">프리셋</s:String>
    <s:String x:Key="Add_HintUseCustom">서비스에 특수한 설정(비표준 알고리즘, 간격 또는 자릿수)이 필요한 경우 "사용자 지정"을 선택하세요.</s:String>
    <s:String x:Key="Add_HintSHA1">대부분의 서비스는 SHA-1을 사용합니다. 서비스에서 별도로 지정하지 않는 한 변경하지 마세요.</s:String>
    <s:String x:Key="Add_HintSHA256">SHA-256은 일부 기업 및 금융 서비스에서 사용됩니다.</s:String>
    <s:String x:Key="Add_HintSHA512">SHA-512는 거의 사용되지 않습니다. 서비스 문서를 확인하세요.</s:String>
    <s:String x:Key="Preset_Custom">사용자 지정</s:String>
    <s:String x:Key="Preset_Standard">표준: Google, GitHub, Microsoft, Discord, Amazon, X 등</s:String>

    <!-- Confirm delete dialog -->
    <s:String x:Key="Delete_Title">삭제 확인</s:String>
    <s:String x:Key="Delete_Message">'{0}'을(를) 삭제하시겠습니까?</s:String>
    <s:String x:Key="Delete_TypeToConfirmPrefix"></s:String>
    <s:String x:Key="Delete_TypeToConfirmKeyword">delete me</s:String>
    <s:String x:Key="Delete_TypeToConfirmSuffix">을(를) 입력하여 확인:</s:String>

    <!-- Rename dialog -->
    <s:String x:Key="Rename_Title">이름 변경</s:String>
    <s:String x:Key="Rename_Name">이름</s:String>

    <!-- Password dialog -->
    <s:String x:Key="Password_Title">비밀번호</s:String>
    <s:String x:Key="Password_Label">비밀번호</s:String>
    <s:String x:Key="Password_Confirm">비밀번호 확인</s:String>
    <s:String x:Key="Password_EnterPassword">비밀번호를 입력하세요.</s:String>
    <s:String x:Key="Password_DontMatch">비밀번호가 일치하지 않습니다.</s:String>
    <s:String x:Key="Password_Error">오류</s:String>

    <!-- Password dialog titles -->
    <s:String x:Key="PwTitle_WinAuth">WinAuth 비밀번호 입력</s:String>
    <s:String x:Key="PwTitle_FilePassword">파일 비밀번호 입력</s:String>
    <s:String x:Key="PwTitle_SetExport">내보내기 비밀번호 설정</s:String>
    <s:String x:Key="PwTitle_SetProtection">비밀번호 보호 설정</s:String>

    <!-- File dialogs -->
    <s:String x:Key="FileDialog_ImportTitle">인증기 가져오기</s:String>
    <s:String x:Key="FileDialog_ExportTitle">인증기 내보내기</s:String>
    <s:String x:Key="FileDialog_ChooseLocation">데이터 파일 위치 선택</s:String>

    <!-- Error messages -->
    <s:String x:Key="Error_ImportFailed">가져오기 실패:</s:String>
    <s:String x:Key="Error_ExportFailed">내보내기 실패:</s:String>
    <s:String x:Key="Error_WrongPassword">비밀번호가 올바르지 않습니다.</s:String>
    <s:String x:Key="Error_ImportError">가져오기 오류</s:String>
    <s:String x:Key="Error_ExportError">내보내기 오류</s:String>

</ResourceDictionary>
